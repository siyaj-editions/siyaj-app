<aside class="lg:sticky lg:top-24">
    <nav class="overflow-hidden rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white shadow-sm">
        {% set links = [
            {route: 'app_account', label: 'Tableau de bord', icon: 'home'},
            {route: 'app_account_profile', label: 'Mon profil', icon: 'user'},
            {route: 'app_account_orders', label: 'Mes commandes', icon: 'orders'},
            {route: 'app_account_address', label: 'Mes adresses', icon: 'location'}
        ] %}

        {% for link in links %}
            {% set active = app.request.attributes.get('_route') == link.route %}
            <a href="{{ path(link.route) }}" class="flex items-center gap-3 border-b border-[rgba(6,27,176,0.06)] px-5 py-4 text-sm font-medium transition-all duration-200 {{ active ? 'bg-[#061BB0] text-white' : 'text-[rgba(6,27,176,0.72)] hover:bg-[rgba(247,244,237,0.75)] hover:text-[#061BB0]' }}">
                {% if link.icon == 'home' %}
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                {% elseif link.icon == 'user' %}
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                {% elseif link.icon == 'orders' %}
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                {% else %}
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"/>
                        <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                {% endif %}
                {{ link.label }}
            </a>
        {% endfor %}

        <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-5 py-4 text-sm font-medium text-[#B4372E] transition-all duration-200 hover:bg-[rgba(180,55,46,0.05)]">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Déconnexion
        </a>
    </nav>
</aside>
