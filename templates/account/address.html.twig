{% extends 'base.html.twig' %}

{% block title %}Mon adresse - SIYAJ Éditions{% endblock %}

{% block body %}
<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container">
        <span class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-gold mb-3">
            Espace personnel
        </span>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-ink mb-2">
            Mes adresses
        </h1>
        <p class="text-lg text-ink/60">
            Ajoutez et gérez vos adresses pour choisir livraison et facturation au checkout
        </p>
    </div>
</section>

<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container">
        <div class="grid lg:grid-cols-4 gap-8 lg:gap-12 items-start">
            {{ include('account/_sidebar.html.twig') }}

            <main class="lg:col-span-3 space-y-6">
                <div class="flex items-center justify-between">
                    <h2 class="font-display text-2xl text-ink">Adresses enregistrées</h2>
                    <button type="button" id="toggle-address-form" class="btn btn-primary">Ajouter une adresse</button>
                </div>

                <div class="grid sm:grid-cols-2 gap-4">
                    {% for address in addresses %}
                        <article class="rounded-[1.8rem] border border-[rgba(6,27,176,0.08)] bg-white p-5 shadow-sm">
                            <div class="flex items-start justify-between gap-3">
                                <div class="text-sm text-ink/80 space-y-1">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <p class="font-semibold text-ink">{{ address.fullName }}</p>
                                        {% if address.isDefault %}
                                            <span class="inline-flex items-center rounded-full bg-sage/15 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-sage">
                                                Par défaut
                                            </span>
                                        {% endif %}
                                    </div>
                                    <p>{{ address.inline }}</p>
                                    {% if address.numero %}<p>Tél: {{ address.numero }}</p>{% endif %}
                                </div>
                                <div class="flex flex-col items-end gap-2">
                                    <a href="{{ path('app_account_address_edit', {id: address.id}) }}" class="text-xs text-ink/60 hover:text-ink hover:underline">
                                        Modifier
                                    </a>
                                    {% if not address.isDefault %}
                                        <form method="post" action="{{ path('app_account_address_default', {id: address.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('default_address_' ~ address.id) }}">
                                            <button type="submit" class="text-xs text-gold hover:underline">Définir par défaut</button>
                                        </form>
                                    {% endif %}
                                    <form method="post" action="{{ path('app_account_address_delete', {id: address.id}) }}" onsubmit="return confirm('Supprimer cette adresse ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_address_' ~ address.id) }}">
                                        <button type="submit" class="text-xs text-wine hover:underline">Supprimer</button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    {% else %}
                        <div class="sm:col-span-2 card p-6 text-center text-ink/60">
                            Aucune adresse enregistrée.
                        </div>
                    {% endfor %}
                </div>

                <div id="address-form-panel" class="hidden rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white p-6 shadow-sm">
                    <h3 class="font-display text-xl text-ink mb-4">Nouvelle adresse</h3>
                    {{ form_start(addressForm, {'attr': {'class': 'space-y-4'}}) }}
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            {{ form_label(addressForm.firstname, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(addressForm.firstname, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(addressForm.firstname) }}
                        </div>
                        <div>
                            {{ form_label(addressForm.lastname, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(addressForm.lastname, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(addressForm.lastname) }}
                        </div>
                        <div class="sm:col-span-2">
                            {{ form_label(addressForm.numero, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(addressForm.numero, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper', 'placeholder': '06 12 34 56 78'}}) }}
                            {{ form_errors(addressForm.numero) }}
                        </div>
                        <div class="sm:col-span-2">
                            {{ form_label(addressForm.street, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(addressForm.street, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(addressForm.street) }}
                        </div>
                        <div class="sm:col-span-2">
                            {{ form_label(addressForm.street2, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(addressForm.street2, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(addressForm.street2) }}
                        </div>
                        <div>
                            {{ form_label(addressForm.postalCode, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(addressForm.postalCode, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(addressForm.postalCode) }}
                        </div>
                        <div>
                            {{ form_label(addressForm.city, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(addressForm.city, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(addressForm.city) }}
                        </div>
                        <div class="sm:col-span-2">
                            {{ form_label(addressForm.country, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            <div
                                class="relative"
                                data-controller="autocomplete"
                                data-autocomplete-choices-value='{{ addressForm.vars.country_choices|json_encode|e('html_attr') }}'
                            >
                                {{ form_widget(addressForm.country, {'attr': {'data-autocomplete-target': 'input', 'data-action': 'input->autocomplete#update focus->autocomplete#open click->autocomplete#open blur->autocomplete#close'}}) }}
                                <div class="absolute left-0 right-0 top-full z-20 mt-2 hidden overflow-hidden rounded-2xl border border-black/10 bg-white shadow-[0_18px_40px_rgba(17,24,39,0.08)]" data-autocomplete-target="menu" data-action="mousedown->autocomplete#handleMouseDown click->autocomplete#select"></div>
                            </div>
                            {{ form_errors(addressForm.country) }}
                        </div>
                        <div class="sm:col-span-2">
                            <div class="flex items-center gap-3 rounded-xl border border-black/10 bg-paper px-4 py-3">
                                {{ form_widget(addressForm.isDefault, {'attr': {'class': 'w-5 h-5 rounded border-black/20'}}) }}
                                {{ form_label(addressForm.isDefault, null, {'label_attr': {'class': 'text-sm text-ink/70'}}) }}
                            </div>
                            {{ form_errors(addressForm.isDefault) }}
                        </div>
                    </div>
                    <div class="pt-4 border-t border-black/5">
                        <button type="submit" class="btn btn-primary">Enregistrer l'adresse</button>
                    </div>
                    {{ form_end(addressForm) }}
                </div>
            </main>
        </div>
    </div>
</section>

<script>
(function () {
    var btn = document.getElementById('toggle-address-form');
    var panel = document.getElementById('address-form-panel');

    if (!btn || !panel) return;
    btn.addEventListener('click', function () {
        panel.classList.toggle('hidden');
    });
})();
</script>
{% endblock %}
