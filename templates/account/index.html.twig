{% extends 'base.html.twig' %}

{% block title %}Mon compte - SIYAJ Éditions{% endblock %}

{% block body %}
<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container">
        <span class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-gold mb-3">
            Espace personnel
        </span>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-ink mb-2">
            Bonjour, {{ user.firstname }}
        </h1>
        <p class="text-lg text-ink/60">
            Gère tes informations et suis tes commandes
        </p>
    </div>
</section>

{# Content #}
<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container">
        <div class="grid lg:grid-cols-4 gap-8 lg:gap-12 items-start">
            {{ include('account/_sidebar.html.twig') }}

            {# Main Content #}
            <main class="lg:col-span-3 space-y-8">
                {# Quick Cards #}
                <div class="grid sm:grid-cols-2 gap-6">
                    {# Profile Card #}
                    <div class="rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white p-6 shadow-sm">
                        <div class="w-12 h-12 rounded-xl bg-cream flex items-center justify-center text-gold mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                        <h3 class="font-display text-lg font-semibold text-ink mb-1">Informations personnelles</h3>
                        <p class="text-sm text-ink/50 mb-1">{{ user.fullName }}</p>
                        <p class="text-sm text-ink/50 mb-4">{{ user.email }}</p>
                        <a href="{{ path('app_account_profile') }}" class="inline-flex items-center gap-1.5 text-sm font-medium text-gold hover:gap-2.5 transition-all duration-200">
                            Modifier
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <polyline points="9 18 15 12 9 6"/>
                            </svg>
                        </a>
                    </div>

                    {# Orders Card #}
                    <div class="rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white p-6 shadow-sm">
                        <div class="w-12 h-12 rounded-xl bg-cream flex items-center justify-center text-gold mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                        </div>
                        <h3 class="font-display text-lg font-semibold text-ink mb-1">Tes commandes</h3>
                        <p class="text-sm text-ink/50 mb-4">Consultez l'historique et le statut de tes commandes</p>
                        <a href="{{ path('app_account_orders') }}" class="inline-flex items-center gap-1.5 text-sm font-medium text-gold hover:gap-2.5 transition-all duration-200">
                            Voir tout
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <polyline points="9 18 15 12 9 6"/>
                            </svg>
                        </a>
                    </div>
                </div>

                {# Recent Orders #}
                <div class="rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white p-6 shadow-sm">
                    <div class="flex items-center justify-between mb-6 pb-4 border-b border-black/5">
                        <h2 class="font-display text-xl font-semibold text-ink">Dernières commandes</h2>
                        <a href="{{ path('app_account_orders') }}" class="text-sm text-gold hover:underline">Voir tout</a>
                    </div>

                    {% if recentOrders|length > 0 %}
                        <div class="space-y-3">
                            {% for order in recentOrders %}
                                <a href="{{ path('app_account_order_show', {id: order.id}) }}" class="group flex flex-col gap-4 rounded-[1.4rem] border border-[rgba(6,27,176,0.06)] bg-[rgba(247,244,237,0.7)] p-4 transition-colors duration-200 hover:bg-[rgba(247,244,237,1)] sm:flex-row sm:items-center">
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-3 mb-1">
                                            <span class="text-[10px] font-semibold uppercase tracking-wider text-ink/40">Commande</span>
                                            <span class="font-display text-base font-semibold text-ink">{{ order.reference }}</span>
                                        </div>
                                        <span class="text-xs text-ink/40">{{ order.createdAt|date('d/m/Y') }}</span>
                                    </div>
                                    <div class="flex items-center justify-between sm:justify-start gap-4 w-full sm:w-auto">
                                        <span class="px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider rounded
                                            {% if order.status.value == 'pending' %}bg-gold/15 text-yellow-700
                                            {% elseif order.status.value == 'paid' %}bg-sage/15 text-sage
                                            {% else %}bg-wine/10 text-wine{% endif %}">
                                            {{ order.status.label }}
                                        </span>
                                        <span class="font-display text-lg font-semibold text-ink min-w-[80px] text-right">
                                            {{ (order.totalCents / 100)|number_format(2, ',', ' ') }} €
                                        </span>
                                        <svg class="hidden sm:block w-5 h-5 text-ink/30 group-hover:text-ink transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <polyline points="9 18 15 12 9 6"/>
                                        </svg>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-12">
                            <p class="text-ink/50 mb-4">Tu n'as pas encore passé de commande.</p>
                            <a href="{{ path('app_catalog') }}" class="btn btn-secondary px-6 py-3">
                                Découvrir le catalogue
                            </a>
                        </div>
                    {% endif %}
                </div>

            </main>
        </div>
    </div>
</section>
{% endblock %}
