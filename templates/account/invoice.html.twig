{% extends 'base.html.twig' %}

{% block title %}Facture {{ order.reference }} - SIYAJ Éditions{% endblock %}

{% block body %}
<section class="py-10 lg:py-14">
    <div class="container max-w-4xl">
        <div class="card p-6 lg:p-8">
            <div class="flex items-start justify-between gap-4 pb-6 border-b border-black/10">
                <div>
                    <p class="text-xs uppercase tracking-[0.2em] text-gold">SIYAJ Editions</p>
                    <h1 class="font-display text-3xl text-ink mt-2">Facture</h1>
                    <p class="text-sm text-ink/60 mt-2">Ref commande: {{ order.reference }}</p>
                </div>
                <div class="text-right text-sm text-ink/70">
                    <p>Date: {{ order.createdAt|date('d/m/Y') }}</p>
                    <p>Statut: {{ order.status.label }}</p>
                </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-6 pt-6">
                <div>
                    <p class="text-xs uppercase tracking-wider text-ink/40 mb-2">Adresse de livraison</p>
                    {% if order.shippingAddress %}
                        <p class="text-sm text-ink">{{ order.shippingAddress.fullName }}</p>
                        <p class="text-sm text-ink/70">{{ order.shippingAddress.inline }}</p>
                        {% if order.shippingAddress.numero %}<p class="text-sm text-ink/70">Tél: {{ order.shippingAddress.numero }}</p>{% endif %}
                    {% endif %}
                </div>
                <div>
                    <p class="text-xs uppercase tracking-wider text-ink/40 mb-2">Adresse de facturation</p>
                    {% if order.billingAddress %}
                        <p class="text-sm text-ink">{{ order.billingAddress.fullName }}</p>
                        <p class="text-sm text-ink/70">{{ order.billingAddress.inline }}</p>
                        {% if order.billingAddress.numero %}<p class="text-sm text-ink/70">Tél: {{ order.billingAddress.numero }}</p>{% endif %}
                    {% endif %}
                </div>
            </div>

            <div class="overflow-x-auto mt-8">
                <table class="min-w-full text-sm">
                    <thead class="bg-paper text-ink/60 uppercase text-xs tracking-wider">
                        <tr>
                            <th class="text-left px-4 py-3">Article</th>
                            <th class="text-left px-4 py-3">Prix unitaire</th>
                            <th class="text-left px-4 py-3">Qte</th>
                            <th class="text-left px-4 py-3">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in order.orderItems %}
                            <tr class="border-t border-black/10">
                                <td class="px-4 py-3 text-ink">{{ item.titleSnapshot }}</td>
                                <td class="px-4 py-3 text-ink/80">{{ (item.priceSnapshot / 100)|number_format(2, ',', ' ') }} €</td>
                                <td class="px-4 py-3 text-ink/80">{{ item.quantity }}</td>
                                <td class="px-4 py-3 text-ink">{{ (item.total / 100)|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="mt-6 pt-4 border-t border-black/10 flex justify-end">
                <p class="font-display text-2xl text-ink">Total: {{ (order.totalCents / 100)|number_format(2, ',', ' ') }} €</p>
            </div>

            <div class="mt-8 flex flex-col sm:flex-row gap-3">
                <button type="button" onclick="window.print()" class="btn btn-primary">Imprimer la facture</button>
                <a href="{{ path('app_account_order_show', {id: order.id}) }}" class="btn btn-secondary">Retour a la commande</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
