{% extends 'base.html.twig' %}

{% block title %}Mes commandes - SIYAG Éditions{% endblock %}

{% block body %}
{# Header #}
<section class="bg-gradient-to-br from-paper to-cream py-12 lg:py-16">
    <div class="container">
        <span class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-gold mb-3">
            Espace personnel
        </span>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-ink mb-2">
            Mes commandes
        </h1>
        <p class="text-lg text-ink/60">
            Consultez l'historique de vos achats
        </p>
    </div>
</section>

{# Content #}
<section class="py-12 lg:py-16">
    <div class="container">
        <div class="grid lg:grid-cols-4 gap-8 lg:gap-12 items-start">
            {# Sidebar Navigation #}
            <aside class="lg:sticky lg:top-24">
                <nav class="bg-white rounded-2xl border border-black/5 overflow-hidden">
                    <a href="{{ path('app_account') }}" class="flex items-center gap-3 px-5 py-4 text-sm font-medium text-ink/70 hover:text-ink hover:bg-cream border-b border-black/5 transition-all duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                            <polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                        Tableau de bord
                    </a>
                    <a href="{{ path('app_account_profile') }}" class="flex items-center gap-3 px-5 py-4 text-sm font-medium text-ink/70 hover:text-ink hover:bg-cream border-b border-black/5 transition-all duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        Mon profil
                    </a>
                    <a href="{{ path('app_account_orders') }}" class="flex items-center gap-3 px-5 py-4 text-sm font-medium bg-ink text-white border-b border-black/5 transition-all duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                        </svg>
                        Mes commandes
                    </a>
                    <a href="{{ path('app_account_address') }}" class="flex items-center gap-3 px-5 py-4 text-sm font-medium text-ink/70 hover:text-ink hover:bg-cream border-b border-black/5 transition-all duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                            <path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"/>
                            <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        Mon adresse
                    </a>
                    <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-5 py-4 text-sm font-medium text-wine hover:bg-wine/5 transition-all duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        Déconnexion
                    </a>
                </nav>
            </aside>

            {# Main Content #}
            <main class="lg:col-span-3">
                {% if orders|length > 0 %}
                    <div class="space-y-4">
                        {% for order in orders %}
                            <div class="bg-white rounded-2xl border border-black/5 overflow-hidden hover:shadow-lg transition-shadow duration-300">
                                {# Order Header #}
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-5 border-b border-black/5">
                                    <div>
                                        <span class="text-[10px] font-semibold uppercase tracking-wider text-ink/40 block">Commande</span>
                                        <span class="font-display text-lg font-semibold text-ink">{{ order.reference }}</span>
                                    </div>
                                    <span class="px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider rounded self-start
                                        {% if order.status.value == 'pending' %}bg-gold/15 text-yellow-700
                                        {% elseif order.status.value == 'paid' %}bg-sage/15 text-sage
                                        {% else %}bg-wine/10 text-wine{% endif %}">
                                        {{ order.status.label }}
                                    </span>
                                </div>

                                {# Order Body #}
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 p-5">
                                    <div class="flex flex-wrap gap-4 sm:gap-6">
                                        <div class="flex items-center gap-2 text-sm text-ink/60">
                                            <svg class="w-4 h-4 text-ink/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                                <line x1="16" y1="2" x2="16" y2="6"/>
                                                <line x1="8" y1="2" x2="8" y2="6"/>
                                                <line x1="3" y1="10" x2="21" y2="10"/>
                                            </svg>
                                            <span>{{ order.createdAt|date('d/m/Y à H:i') }}</span>
                                        </div>
                                        <div class="flex items-center gap-2 text-sm text-ink/60">
                                            <svg class="w-4 h-4 text-ink/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                                            </svg>
                                            <span>{{ order.orderItems|length }} article{% if order.orderItems|length > 1 %}s{% endif %}</span>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-[10px] font-semibold uppercase tracking-wider text-ink/40 block">Total</span>
                                        <span class="font-display text-xl font-semibold text-ink">{{ (order.totalCents / 100)|number_format(2, ',', ' ') }} €</span>
                                    </div>
                                </div>

                                {# Order Action #}
                                <a href="{{ path('app_account_order_show', {id: order.id}) }}" class="flex items-center justify-center gap-2 px-5 py-4 bg-paper text-ink text-sm font-medium hover:bg-cream hover:text-gold transition-all duration-200">
                                    Voir le détail
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <polyline points="9 18 15 12 9 6"/>
                                    </svg>
                                </a>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    {# Empty State #}
                    <div class="text-center py-16 bg-white rounded-2xl border border-black/5">
                        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-cream flex items-center justify-center text-ink/20">
                            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                        </div>
                        <h3 class="font-display text-2xl font-semibold text-ink mb-2">Aucune commande</h3>
                        <p class="text-ink/60 mb-6">Vous n'avez pas encore passé de commande.</p>
                        <a href="{{ path('app_catalog') }}" class="btn btn-primary px-8 py-3">
                            Découvrir le catalogue
                        </a>
                    </div>
                {% endif %}
            </main>
        </div>
    </div>
</section>
{% endblock %}
