{% extends 'base.html.twig' %}

{% block title %}Mes commandes - SIYAJ Éditions{% endblock %}

{% block body %}
{# Header #}
<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container">
        <span class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-gold mb-3">
            Espace personnel
        </span>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-ink mb-2">
            Mes commandes
        </h1>
        <p class="text-lg text-ink/60">
            Consultez l'historique de vos achats
        </p>
    </div>
</section>

{# Content #}
<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container">
        <div class="grid lg:grid-cols-4 gap-8 lg:gap-12 items-start">
            {{ include('account/_sidebar.html.twig') }}

            {# Main Content #}
            <main class="lg:col-span-3">
                {% if orders|length > 0 %}
                    {% set paymentBadgeClasses = {
                        pending: 'bg-gold/15 text-yellow-700',
                        paid: 'bg-sage/15 text-sage',
                        cancelled: 'bg-wine/10 text-wine'
                    } %}
                    {% set sendBadgeClasses = {
                        processing: 'bg-ink/5 text-ink/65',
                        sent: 'bg-[#061BB0]/10 text-[#061BB0]',
                        received: 'bg-sage/15 text-sage'
                    } %}
                    <div class="space-y-4">
                        {% for order in orders %}
                            <div class="overflow-hidden rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white shadow-sm transition-shadow duration-300 hover:shadow-md">
                                {# Order Header #}
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-5 border-b border-black/5">
                                    <div>
                                        <span class="text-[10px] font-semibold uppercase tracking-wider text-ink/40 block">Commande</span>
                                        <span class="font-display text-lg font-semibold text-ink">{{ order.reference }}</span>
                                    </div>
                                    <div class="flex flex-wrap items-center gap-2 self-start">
                                        <span class="px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider rounded {{ paymentBadgeClasses[order.status.value] ?? 'bg-ink/5 text-ink/65' }}">
                                            {{ order.status.label }}
                                        </span>
                                        <span class="px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider rounded {{ sendBadgeClasses[order.sendStatus.value] ?? 'bg-ink/5 text-ink/65' }}">
                                            {{ order.sendStatus.label }}
                                        </span>
                                    </div>
                                </div>

                                {# Order Body #}
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 p-5">
                                    <div class="flex flex-wrap gap-4 sm:gap-6">
                                        <div class="flex items-center gap-2 text-sm text-ink/60">
                                            <svg class="w-4 h-4 text-ink/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                                <line x1="16" y1="2" x2="16" y2="6"/>
                                                <line x1="8" y1="2" x2="8" y2="6"/>
                                                <line x1="3" y1="10" x2="21" y2="10"/>
                                            </svg>
                                            <span>{{ order.createdAt|date('d/m/Y à H:i') }}</span>
                                        </div>
                                        <div class="flex items-center gap-2 text-sm text-ink/60">
                                            <svg class="w-4 h-4 text-ink/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                                            </svg>
                                            <span>{{ order.orderItems|length }} article{% if order.orderItems|length > 1 %}s{% endif %}</span>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-[10px] font-semibold uppercase tracking-wider text-ink/40 block">Total</span>
                                        <span class="font-display text-xl font-semibold text-ink">{{ (order.totalCents / 100)|number_format(2, ',', ' ') }} €</span>
                                    </div>
                                </div>

                                {# Order Action #}
                                <a href="{{ path('app_account_order_show', {id: order.id}) }}" class="flex items-center justify-center gap-2 px-5 py-4 bg-paper text-ink text-sm font-medium hover:bg-cream hover:text-gold transition-all duration-200">
                                    Voir le détail
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <polyline points="9 18 15 12 9 6"/>
                                    </svg>
                                </a>
                            </div>
                        {% endfor %}
                    </div>

                    {% if showPagination %}
                        <nav class="mt-8 flex flex-wrap items-center justify-center gap-2" aria-label="Pagination des commandes">
                            {% if currentPage > 1 %}
                                <a
                                    href="{{ path('app_account_orders', {page: currentPage - 1}) }}"
                                    class="inline-flex min-h-11 items-center justify-center rounded-full border border-[rgba(6,27,176,0.12)] bg-white px-4 text-sm font-medium text-ink transition-colors duration-200 hover:border-gold hover:text-gold"
                                >
                                    Précédent
                                </a>
                            {% endif %}

                            {% for page in 1..totalPages %}
                                <a
                                    href="{{ path('app_account_orders', {page: page}) }}"
                                    class="inline-flex h-11 min-w-11 items-center justify-center rounded-full border px-4 text-sm font-semibold transition-colors duration-200 {{ page == currentPage ? 'border-transparent bg-ink text-white' : 'border-[rgba(6,27,176,0.12)] bg-white text-ink hover:border-gold hover:text-gold' }}"
                                    aria-current="{{ page == currentPage ? 'page' : 'false' }}"
                                >
                                    {{ page }}
                                </a>
                            {% endfor %}

                            {% if currentPage < totalPages %}
                                <a
                                    href="{{ path('app_account_orders', {page: currentPage + 1}) }}"
                                    class="inline-flex min-h-11 items-center justify-center rounded-full border border-[rgba(6,27,176,0.12)] bg-white px-4 text-sm font-medium text-ink transition-colors duration-200 hover:border-gold hover:text-gold"
                                >
                                    Suivant
                                </a>
                            {% endif %}
                        </nav>
                    {% endif %}
                {% else %}
                    {# Empty State #}
                    <div class="rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white py-16 text-center shadow-sm">
                        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-cream flex items-center justify-center text-ink/20">
                            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                        </div>
                        <h3 class="font-display text-2xl font-semibold text-ink mb-2">Aucune commande</h3>
                        <p class="text-ink/60 mb-6">Vous n'avez pas encore passé de commande.</p>
                        <a href="{{ path('app_catalog') }}" class="btn btn-primary px-8 py-3">
                            Découvrir le catalogue
                        </a>
                    </div>
                {% endif %}
            </main>
        </div>
    </div>
</section>
{% endblock %}
