{% extends 'base.html.twig' %}

{% block title %}Mon profil - SIYAJ Éditions{% endblock %}

{% block body %}
{# Header #}
<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container">
        <span class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-gold mb-3">
            Espace personnel
        </span>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-ink mb-2">
            Mon profil
        </h1>
        <p class="text-lg text-ink/60">
            Modifie tes informations personnelles
        </p>
    </div>
</section>

{# Content #}
<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container">
        <div class="grid lg:grid-cols-4 gap-8 lg:gap-12 items-start">
            {{ include('account/_sidebar.html.twig') }}

            {# Main Content #}
            <main class="lg:col-span-3">
                <div class="rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white p-6 shadow-sm lg:p-8">
                    {{ form_start(profileForm) }}

                    {# Personal Information Section #}
                    <div class="mb-8 pb-8 border-b border-black/5">
                        <h2 class="font-display text-xl font-semibold text-ink mb-1">Informations personnelles</h2>
                        <p class="text-sm text-ink/50 mb-6">Ces informations seront utilisées pour tes commandes</p>

                        <div class="grid sm:grid-cols-2 gap-4 mb-4">
                            <div>
                                {{ form_label(profileForm.firstname, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                                {{ form_widget(profileForm.firstname, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper focus:bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all duration-200 outline-none'}}) }}
                                {{ form_errors(profileForm.firstname) }}
                            </div>
                            <div>
                                {{ form_label(profileForm.lastname, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                                {{ form_widget(profileForm.lastname, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper focus:bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all duration-200 outline-none'}}) }}
                                {{ form_errors(profileForm.lastname) }}
                            </div>
                        </div>

                        <div>
                            {{ form_label(profileForm.email, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(profileForm.email, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper focus:bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all duration-200 outline-none'}}) }}
                            {{ form_errors(profileForm.email) }}
                        </div>

                        <div class="mt-4">
                            {{ form_label(profileForm.numero, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(profileForm.numero, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper focus:bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all duration-200 outline-none', 'placeholder': '06 12 34 56 78'}}) }}
                            {{ form_errors(profileForm.numero) }}
                        </div>
                    </div>

                    {# Security Section #}
                    <div class="mb-8">
                        <h2 class="font-display text-xl font-semibold text-ink mb-1">Sécurité</h2>
                        <p class="text-sm text-ink/50 mb-6">Laissez vide si vous ne souhaitez pas modifier votre mot de passe</p>

                        <div class="grid sm:grid-cols-2 gap-4">
                            <div>
                                {{ form_label(profileForm.plainPassword.first, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                                {{ form_widget(profileForm.plainPassword.first, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper focus:bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all duration-200 outline-none'}}) }}
                                {{ form_errors(profileForm.plainPassword.first) }}
                            </div>
                            <div>
                                {{ form_label(profileForm.plainPassword.second, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                                {{ form_widget(profileForm.plainPassword.second, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper focus:bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all duration-200 outline-none'}}) }}
                                {{ form_errors(profileForm.plainPassword.second) }}
                            </div>
                        </div>
                    </div>

                    {# Actions #}
                    <div class="flex flex-col sm:flex-row gap-3 pt-6 border-t border-black/5">
                        <button type="submit" class="btn btn-primary">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                                <polyline points="17 21 17 13 7 13 7 21"/>
                                <polyline points="7 3 7 8 15 8"/>
                            </svg>
                            Enregistrer les modifications
                        </button>
                        <a href="{{ path('app_account') }}" class="btn btn-secondary">
                            Annuler
                        </a>
                    </div>

                    {{ form_end(profileForm) }}
                </div>
            </main>
        </div>
    </div>
</section>
{% endblock %}
