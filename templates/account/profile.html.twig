{% extends 'base.html.twig' %}

{% block title %}Mon profil - SIYAG{% endblock %}

{% block body %}
<h1 class="mb-4">Mon profil</h1>

<div class="row">
    <div class="col-md-6">
        {{ form_start(profileForm) }}
            <div class="mb-3">
                {{ form_row(profileForm.email) }}
            </div>
            <div class="mb-3">
                {{ form_row(profileForm.firstname) }}
            </div>
            <div class="mb-3">
                {{ form_row(profileForm.lastname) }}
            </div>
            <hr>
            <h4>Changer mon mot de passe</h4>
            <div class="mb-3">
                {{ form_row(profileForm.plainPassword.first) }}
            </div>
            <div class="mb-3">
                {{ form_row(profileForm.plainPassword.second) }}
            </div>
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a href="{{ path('app_account') }}" class="btn btn-secondary">Annuler</a>
        {{ form_end(profileForm) }}
    </div>
</div>
{% endblock %}
