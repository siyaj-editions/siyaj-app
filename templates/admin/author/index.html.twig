{% extends 'base.html.twig' %}

{% block title %}Gestion des auteurs - SIYAG{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Gestion des auteurs</h1>
    <a href="{{ path('app_admin_author_new') }}" class="btn btn-primary">Ajouter un auteur</a>
</div>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Nombre de livres</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for author in authors %}
                <tr>
                    <td>{{ author.name }}</td>
                    <td>{{ author.books|length }}</td>
                    <td>
                        <a href="{{ path('app_admin_author_edit', {id: author.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                        <form action="{{ path('app_admin_author_delete', {id: author.id}) }}" method="post" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ author.id) }}">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Êtes-vous sûr ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="3">Aucun auteur</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">Retour au dashboard</a>
{% endblock %}
