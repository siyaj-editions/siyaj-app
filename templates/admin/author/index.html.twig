{% extends 'base.html.twig' %}

{% block title %}Gestion des auteurs - SIYAG{% endblock %}

{% block body %}
<section class="py-12 md:py-16">
    <div class="container space-y-6">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
            <div>
                <p class="text-sm text-sage">Administration</p>
                <h1 class="text-3xl sm:text-4xl md:text-5xl text-ink">Auteurs</h1>
            </div>
            <a href="{{ path('app_admin_author_new') }}" class="btn btn-primary px-6 py-3 w-full sm:w-auto text-center justify-center">Ajouter un auteur</a>
        </div>

        <section class="card p-0 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-[640px] w-full text-sm">
                    <thead class="bg-paper text-ink/70 uppercase text-xs tracking-wide">
                        <tr>
                            <th class="text-left px-6 py-4">Nom</th>
                            <th class="text-left px-6 py-4">Nombre de livres</th>
                            <th class="text-right px-6 py-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for author in authors %}
                            <tr class="border-t border-black/5 hover:bg-paper/60 transition-colors">
                                <td class="px-6 py-4 font-medium text-ink">{{ author.name }}</td>
                                <td class="px-6 py-4 text-ink/80">{{ author.books|length }}</td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-wrap sm:flex-nowrap items-center justify-end gap-2">
                                        <a href="{{ path('app_admin_author_edit', {id: author.id}) }}" class="inline-flex items-center px-4 py-2 rounded-lg bg-paper text-ink text-xs font-medium hover:bg-cream transition-colors">Modifier</a>
                                        <form action="{{ path('app_admin_author_delete', {id: author.id}) }}" method="post" class="inline" onsubmit="return confirm('Êtes-vous sûr ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ author.id) }}">
                                            <button type="submit" class="inline-flex items-center px-4 py-2 rounded-lg bg-rose-600 text-white text-xs font-medium hover:bg-rose-700 transition-colors">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr class="border-t border-black/5">
                                <td colspan="3" class="px-6 py-8 text-center text-sage">Aucun auteur.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary px-6 py-3 w-full sm:w-auto text-center justify-center">Retour au dashboard</a>
    </div>
</section>
{% endblock %}
