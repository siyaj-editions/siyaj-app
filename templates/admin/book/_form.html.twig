{{ form_start(bookForm, {'attr': {'class': 'space-y-8'}}) }}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {{ form_row(bookForm.title) }}
        {{ form_row(bookForm.isbn) }}
        <div class="space-y-3">
            <div class="space-y-3">
                {{ form_label(bookForm.coverImageFile) }}
                <div
                    class="upload-zone"
                    data-controller="upload-dropzone"
                    data-upload-dropzone-empty-label-value="Glissez-déposez votre image ici ou cliquez pour la sélectionner"
                >
                    <div
                        class="space-y-3"
                        data-upload-dropzone-target="zone"
                        data-action="click->upload-dropzone#open dragover->upload-dropzone#dragOver dragleave->upload-dropzone#dragLeave drop->upload-dropzone#drop"
                    >
                        <div class="upload-zone-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 16.5A2.5 2.5 0 016.5 14H7a5 5 0 019.7-1.5A3.5 3.5 0 0117.5 19H7a3 3 0 01-3-3z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8v8m0-8l-3 3m3-3l3 3" />
                            </svg>
                        </div>
                        <div class="space-y-1">
                            <p class="upload-zone-name" data-upload-dropzone-target="name">Glissez-déposez votre image ici ou cliquez pour la sélectionner</p>
                            <p class="upload-zone-help">Formats acceptés : JPG, PNG, WEBP, GIF. Taille maximum : 8 Mo.</p>
                        </div>
                        <div class="hidden pt-2" data-upload-dropzone-target="preview">
                            <img src="" alt="Aperçu de la couverture" class="h-28 w-20 rounded-xl object-cover shadow-sm" data-upload-dropzone-target="previewImage">
                        </div>
                    </div>
                    {{ form_widget(bookForm.coverImageFile, {
                        attr: {
                            class: 'upload-zone-input',
                            'data-upload-dropzone-target': 'input',
                            'data-action': 'change->upload-dropzone#updateLabel change->upload-dropzone#updatePreview'
                        }
                    }) }}
                </div>
                {{ form_help(bookForm.coverImageFile) }}
                {{ form_errors(bookForm.coverImageFile) }}
            </div>
            {% if bookForm.vars.data and bookForm.vars.data.coverImage %}
                <div class="rounded-2xl border border-black/10 bg-paper/60 p-4">
                    <p class="text-xs uppercase tracking-[0.16em] text-ink/60">Couverture actuelle</p>
                    <img src="{{ bookForm.vars.data.coverImage }}" alt="{{ bookForm.vars.data.title }}" class="mt-3 h-40 w-28 rounded-xl object-cover">
                </div>
            {% endif %}
        </div>
        {{ form_row(bookForm.priceCents) }}
        {{ form_row(bookForm.format) }}
        {{ form_row(bookForm.stock) }}
        <div class="space-y-3">
            {{ form_label(bookForm.publishedAt) }}
            <div class="date-field-shell" data-controller="date-picker">
                {{ form_widget(bookForm.publishedAt, {
                    attr: {
                        class: 'date-field-input',
                        'data-date-picker-target': 'input'
                    }
                }) }}
                <button type="button" class="date-field-trigger" data-action="click->date-picker#open" aria-label="Choisir une date">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 7V3m8 4V3m-9 8h10m-11 9h12a2 2 0 002-2V7a2 2 0 00-2-2H6a2 2 0 00-2 2v11a2 2 0 002 2z" />
                    </svg>
                </button>
            </div>
            {{ form_help(bookForm.publishedAt) }}
            {{ form_errors(bookForm.publishedAt) }}
        </div>
    </div>

    {{ form_row(bookForm.description) }}

    <div
        class="space-y-4 rounded-2xl border border-black/10 p-5"
        data-controller="collection"
        data-collection-index-value="{{ bookForm.authorNames|length }}"
        data-collection-item-selector-value="[data-author-entry]"
        data-collection-template-value="{% apply escape('html_attr') %}<div class='flex items-center gap-3 mb-3' data-author-entry data-collection-item><div class='flex-1 relative' data-controller='autocomplete' data-autocomplete-choices-value='{{ bookForm.vars.author_choices|json_encode|e('html_attr') }}'>{{ form_widget(bookForm.authorNames.vars.prototype, {'attr': {'data-autocomplete-target': 'input', 'data-action': 'input->autocomplete#update focus->autocomplete#open click->autocomplete#open blur->autocomplete#close', 'autocomplete': 'off'}}) }}<div class='absolute left-0 right-0 top-full z-20 mt-2 hidden overflow-hidden rounded-2xl border border-black/10 bg-white shadow-[0_18px_40px_rgba(17,24,39,0.08)]' data-autocomplete-target='menu' data-action='mousedown->autocomplete#handleMouseDown click->autocomplete#select'></div></div><button type='button' class='btn btn-secondary px-3 py-2' data-action='click->collection#remove'>Retirer</button></div>{% endapply %}"
    >
        <div class="flex items-center justify-between gap-4">
            <div>
                <h2 class="text-lg font-semibold text-ink">Auteur(s)</h2>
                <p class="text-sm text-ink/60">Ajoute un ou plusieurs auteurs. Un nouvel auteur sera créé automatiquement s'il n'existe pas encore.</p>
            </div>
            <button
                type="button"
                class="btn btn-secondary px-4 py-2"
                data-action="click->collection#add"
            >
                +
            </button>
        </div>

        <div data-collection-target="list">
            {% for authorField in bookForm.authorNames %}
                <div class="flex items-center gap-3 mb-3" data-author-entry>
                    <div
                        class="flex-1 relative"
                        data-controller="autocomplete"
                        data-autocomplete-choices-value='{{ bookForm.vars.author_choices|json_encode|e('html_attr') }}'
                    >
                        {{ form_widget(authorField, {'attr': {'data-autocomplete-target': 'input', 'data-action': 'input->autocomplete#update focus->autocomplete#open click->autocomplete#open blur->autocomplete#close', 'autocomplete': 'off'}}) }}
                        <div class="absolute left-0 right-0 top-full z-20 mt-2 hidden overflow-hidden rounded-2xl border border-black/10 bg-white shadow-[0_18px_40px_rgba(17,24,39,0.08)]" data-autocomplete-target="menu" data-action="mousedown->autocomplete#handleMouseDown click->autocomplete#select"></div>
                    </div>
                    <button type="button" class="btn btn-secondary px-3 py-2" data-action="click->collection#remove">Retirer</button>
                </div>
            {% endfor %}
        </div>

        {{ form_errors(bookForm.authorNames) }}
    </div>

    <div
        class="space-y-4 rounded-2xl border border-black/10 p-5"
        data-controller="collection"
        data-collection-index-value="{{ bookForm.genreNames|length }}"
        data-collection-item-selector-value="[data-genre-entry]"
        data-collection-template-value="{% apply escape('html_attr') %}<div class='flex items-center gap-3 mb-3' data-genre-entry data-collection-item><div class='flex-1 relative' data-controller='autocomplete' data-autocomplete-choices-value='{{ bookForm.vars.genre_choices|json_encode|e('html_attr') }}'>{{ form_widget(bookForm.genreNames.vars.prototype, {'attr': {'data-autocomplete-target': 'input', 'data-action': 'input->autocomplete#update focus->autocomplete#open click->autocomplete#open blur->autocomplete#close', 'autocomplete': 'off'}}) }}<div class='absolute left-0 right-0 top-full z-20 mt-2 hidden overflow-hidden rounded-2xl border border-black/10 bg-white shadow-[0_18px_40px_rgba(17,24,39,0.08)]' data-autocomplete-target='menu' data-action='mousedown->autocomplete#handleMouseDown click->autocomplete#select'></div></div><button type='button' class='btn btn-secondary px-3 py-2' data-action='click->collection#remove'>Retirer</button></div>{% endapply %}"
    >
        <div class="flex items-center justify-between gap-4">
            <div>
                <h2 class="text-lg font-semibold text-ink">Genre(s)</h2>
                <p class="text-sm text-ink/60">Ajoute un ou plusieurs genres. Un nouveau genre sera créé automatiquement s'il n'existe pas encore.</p>
            </div>
            <button
                type="button"
                class="btn btn-secondary px-4 py-2"
                data-action="click->collection#add"
            >
                +
            </button>
        </div>

        <div data-collection-target="list">
            {% for genreField in bookForm.genreNames %}
                <div class="flex items-center gap-3 mb-3" data-genre-entry>
                    <div
                        class="flex-1 relative"
                        data-controller="autocomplete"
                        data-autocomplete-choices-value='{{ bookForm.vars.genre_choices|json_encode|e('html_attr') }}'
                    >
                        {{ form_widget(genreField, {'attr': {'data-autocomplete-target': 'input', 'data-action': 'input->autocomplete#update focus->autocomplete#open click->autocomplete#open blur->autocomplete#close', 'autocomplete': 'off'}}) }}
                        <div class="absolute left-0 right-0 top-full z-20 mt-2 hidden overflow-hidden rounded-2xl border border-black/10 bg-white shadow-[0_18px_40px_rgba(17,24,39,0.08)]" data-autocomplete-target="menu" data-action="mousedown->autocomplete#handleMouseDown click->autocomplete#select"></div>
                    </div>
                    <button type="button" class="btn btn-secondary px-3 py-2" data-action="click->collection#remove">Retirer</button>
                </div>
            {% endfor %}
        </div>

        {{ form_errors(bookForm.genreNames) }}
    </div>

    <div class="rounded-2xl border border-black/10 p-5">
        <div class="admin-checkbox-row">
            {{ form_widget(bookForm.isActive) }}
            {{ form_label(bookForm.isActive) }}
        </div>
        {{ form_errors(bookForm.isActive) }}
    </div>

    <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-black/5">
        <button type="submit" class="btn btn-primary">{{ submit_label }}</button>
        <a href="{{ path('app_admin_book_index') }}" class="btn btn-secondary">Annuler</a>
    </div>
{{ form_end(bookForm) }}
