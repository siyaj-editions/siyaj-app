{% extends 'base.html.twig' %}

{% block title %}Modifier livre - SIYAJ{% endblock %}

{% block body %}
<section class="py-12 md:py-16">
    <div class="container max-w-4xl space-y-6">
        <div>
            <p class="text-sm text-sage">Administration</p>
            <h1 class="text-4xl md:text-5xl text-ink">Modifier le livre</h1>
            <p class="mt-2 text-sage">{{ book.title }}</p>
        </div>

        <section class="card p-6 md:p-8">
            {% include 'admin/book/_form.html.twig' with {bookForm: bookForm, submit_label: 'Enregistrer'} only %}
        </section>
    </div>
</section>
{% endblock %}
