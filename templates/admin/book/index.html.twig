{% extends 'base.html.twig' %}

{% block title %}Gestion des livres - SIYAG{% endblock %}

{% block body %}
<section class="py-12 md:py-16">
    <div class="container space-y-6">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
            <div>
                <p class="text-sm text-sage">Administration</p>
                <h1 class="text-4xl md:text-5xl text-ink">Livres</h1>
            </div>
            <a href="{{ path('app_admin_book_new') }}" class="btn btn-primary px-6 py-3">Ajouter un livre</a>
        </div>

        <section class="card p-0 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead class="bg-paper text-ink/70 uppercase text-xs tracking-wide">
                        <tr>
                            <th class="text-left px-6 py-4">Titre</th>
                            <th class="text-left px-6 py-4">Auteurs</th>
                            <th class="text-left px-6 py-4">Prix</th>
                            <th class="text-left px-6 py-4">Stock</th>
                            <th class="text-left px-6 py-4">Actif</th>
                            <th class="text-right px-6 py-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for book in books %}
                            <tr class="border-t border-black/5 hover:bg-paper/60 transition-colors">
                                <td class="px-6 py-4 font-medium text-ink">{{ book.title }}</td>
                                <td class="px-6 py-4 text-ink/80">{{ book.authorsNames }}</td>
                                <td class="px-6 py-4 text-ink">{{ (book.priceCents / 100)|number_format(2, ',', ' ') }} €</td>
                                <td class="px-6 py-4 text-ink/80">{{ book.stock ?? 'N/A' }}</td>
                                <td class="px-6 py-4">
                                    {% if book.isActive %}
                                        <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">Oui</span>
                                    {% else %}
                                        <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium bg-rose-100 text-rose-800">Non</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="{{ path('app_admin_book_edit', {id: book.id}) }}" class="inline-flex items-center px-4 py-2 rounded-lg bg-paper text-ink text-xs font-medium hover:bg-cream transition-colors">Modifier</a>
                                        <form action="{{ path('app_admin_book_delete', {id: book.id}) }}" method="post" class="inline" onsubmit="return confirm('Êtes-vous sûr ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                                            <button type="submit" class="inline-flex items-center px-4 py-2 rounded-lg bg-rose-600 text-white text-xs font-medium hover:bg-rose-700 transition-colors">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr class="border-t border-black/5">
                                <td colspan="6" class="px-6 py-8 text-center text-sage">Aucun livre.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary px-6 py-3">Retour au dashboard</a>
    </div>
</section>
{% endblock %}
