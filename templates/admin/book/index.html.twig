{% extends 'base.html.twig' %}

{% block title %}Gestion des livres - SIYAG{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Gestion des livres</h1>
    <a href="{{ path('app_admin_book_new') }}" class="btn btn-primary">Ajouter un livre</a>
</div>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Auteurs</th>
                <th>Prix</th>
                <th>Stock</th>
                <th>Actif</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for book in books %}
                <tr>
                    <td>{{ book.title }}</td>
                    <td>{{ book.authorsNames }}</td>
                    <td>{{ (book.priceCents / 100)|number_format(2, ',', ' ') }} €</td>
                    <td>{{ book.stock ?? 'N/A' }}</td>
                    <td>
                        {% if book.isActive %}
                            <span class="badge bg-success">Oui</span>
                        {% else %}
                            <span class="badge bg-danger">Non</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('app_admin_book_edit', {id: book.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                        <form action="{{ path('app_admin_book_delete', {id: book.id}) }}" method="post" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Êtes-vous sûr ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6">Aucun livre</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">Retour au dashboard</a>
{% endblock %}
