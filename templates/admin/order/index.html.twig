{% extends 'base.html.twig' %}

{% block title %}Gestion des commandes - SIYAG{% endblock %}

{% block body %}
<h1 class="mb-4">Gestion des commandes</h1>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Référence</th>
                <th>Client</th>
                <th>Date</th>
                <th>Statut</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for order in orders %}
                <tr>
                    <td>{{ order.reference }}</td>
                    <td>{{ order.user.fullName }}</td>
                    <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                    <td><span class="badge bg-{{ order.status.badgeClass }}">{{ order.status.label }}</span></td>
                    <td>{{ (order.totalCents / 100)|number_format(2, ',', ' ') }} €</td>
                    <td><a href="{{ path('app_admin_order_show', {id: order.id}) }}" class="btn btn-sm btn-primary">Voir</a></td>
                </tr>
            {% else %}
                <tr><td colspan="6">Aucune commande</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">Retour au dashboard</a>
{% endblock %}
