{% extends 'base.html.twig' %}

{% block title %}Commande {{ order.reference }} - SIYAG{% endblock %}

{% block body %}
<section class="py-12 md:py-16">
    <div class="container space-y-6">
        {% set statusClass = {
            'pending': 'bg-amber-100 text-amber-800',
            'paid': 'bg-emerald-100 text-emerald-800',
            'canceled': 'bg-rose-100 text-rose-800',
            'refunded': 'bg-slate-200 text-slate-700'
        }[order.status.value]|default('bg-slate-100 text-slate-700') %}

        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
            <div>
                <p class="text-sm text-sage">Administration</p>
                <h1 class="text-4xl md:text-5xl text-ink">Commande {{ order.reference }}</h1>
            </div>
            <a href="{{ path('app_admin_order_index') }}" class="btn btn-secondary px-6 py-3">Retour aux commandes</a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <section class="lg:col-span-1 card p-6 space-y-4">
                <h2 class="text-2xl text-ink">Informations</h2>
                <div class="space-y-2 text-sm text-ink/80">
                    <p><span class="text-ink/50">Client:</span> {{ order.user.fullName }}</p>
                    <p><span class="text-ink/50">Email:</span> {{ order.user.email }}</p>
                    <p><span class="text-ink/50">Date:</span> {{ order.createdAt|date('d/m/Y H:i') }}</p>
                    <p><span class="text-ink/50">Total:</span> {{ (order.totalCents / 100)|number_format(2, ',', ' ') }} €</p>
                </div>
                <div>
                    <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium {{ statusClass }}">{{ order.status.label }}</span>
                </div>
            </section>

            <section class="lg:col-span-2 card p-6 space-y-4">
                <h2 class="text-2xl text-ink">Changer le statut</h2>
                <form action="{{ path('app_admin_order_status', {id: order.id}) }}" method="post" class="space-y-4">
                    <div>
                        <label for="status" class="block text-sm font-medium text-ink mb-2">Nouveau statut</label>
                        <select id="status" name="status">
                            <option value="pending" {% if order.status.value == 'pending' %}selected{% endif %}>En attente</option>
                            <option value="paid" {% if order.status.value == 'paid' %}selected{% endif %}>Payée</option>
                            <option value="canceled" {% if order.status.value == 'canceled' %}selected{% endif %}>Annulée</option>
                            <option value="refunded" {% if order.status.value == 'refunded' %}selected{% endif %}>Remboursée</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Mettre à jour</button>
                </form>
            </section>
        </div>

        <section class="card p-0 overflow-hidden">
            <div class="px-6 py-5 border-b border-black/5">
                <h3 class="text-2xl text-ink">Articles commandés</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead class="bg-paper text-ink/70 uppercase text-xs tracking-wide">
                        <tr>
                            <th class="text-left px-6 py-4">Livre</th>
                            <th class="text-left px-6 py-4">Prix unitaire</th>
                            <th class="text-left px-6 py-4">Quantité</th>
                            <th class="text-left px-6 py-4">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in order.orderItems %}
                            <tr class="border-t border-black/5 hover:bg-paper/60 transition-colors">
                                <td class="px-6 py-4 text-ink font-medium">{{ item.titleSnapshot }}</td>
                                <td class="px-6 py-4 text-ink/80">{{ (item.priceSnapshot / 100)|number_format(2, ',', ' ') }} €</td>
                                <td class="px-6 py-4 text-ink/80">{{ item.quantity }}</td>
                                <td class="px-6 py-4 text-ink">{{ (item.total / 100)|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr class="border-t border-black/5 bg-paper/70">
                            <th colspan="3" class="px-6 py-4 text-right text-ink/70">Total</th>
                            <th class="px-6 py-4 text-left text-ink">{{ (order.totalCents / 100)|number_format(2, ',', ' ') }} €</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>
    </div>
</section>
{% endblock %}
