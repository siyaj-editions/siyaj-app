{% extends 'base.html.twig' %}

{% block title %}Panier - SIYAG{% endblock %}

{% block body %}
<h1 class="mb-4">Mon Panier</h1>

{% if cart is empty %}
    <p>Votre panier est vide.</p>
    <a href="{{ path('app_catalog') }}" class="btn btn-primary">Voir le catalogue</a>
{% else %}
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Livre</th>
                    <th>Prix unitaire</th>
                    <th>Quantité</th>
                    <th>Total</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for item in cart %}
                    <tr>
                        <td>
                            <strong>{{ item.book.title }}</strong><br>
                            <small class="text-muted">{{ item.book.authorsNames }}</small>
                        </td>
                        <td>{{ (item.book.priceCents / 100)|number_format(2, ',', ' ') }} €</td>
                        <td>
                            <div class="btn-group" role="group">
                                <form action="{{ path('app_cart_decrement', {id: item.book.id}) }}" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">-</button>
                                </form>
                                <span class="btn btn-sm btn-outline-secondary disabled">{{ item.quantity }}</span>
                                <form action="{{ path('app_cart_increment', {id: item.book.id}) }}" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">+</button>
                                </form>
                            </div>
                        </td>
                        <td>{{ ((item.book.priceCents * item.quantity) / 100)|number_format(2, ',', ' ') }} €</td>
                        <td>
                            <form action="{{ path('app_cart_remove', {id: item.book.id}) }}" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" class="text-end">Total :</th>
                    <th colspan="2">{{ total|number_format(2, ',', ' ') }} €</th>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="d-flex justify-content-between mt-4">
        <a href="{{ path('app_catalog') }}" class="btn btn-secondary">Continuer les achats</a>
        {% if app.user %}
            <form action="{{ path('app_checkout_create') }}" method="post">
                <button type="submit" class="btn btn-primary btn-lg">Passer au paiement</button>
            </form>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg">Se connecter pour commander</a>
        {% endif %}
    </div>
{% endif %}
{% endblock %}
