{% extends 'base.html.twig' %}

{% block title %}Panier - SIYAJ Éditions{% endblock %}

{% block body %}
{# Header #}
<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container text-center">
        <span class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-gold mb-3">
            Votre sélection
        </span>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-ink">
            Mon Panier
        </h1>
    </div>
</section>

{# Content #}
<section class="bg-[#F7F4ED] py-12 lg:py-16">
    <div class="container">
        {% if cart is empty %}
            {# Empty Cart #}
            <div class="max-w-md mx-auto text-center py-16">
                <div class="w-24 h-24 mx-auto mb-8 rounded-full bg-cream flex items-center justify-center text-ink/20">
                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                    </svg>
                </div>
                <h2 class="font-display text-2xl font-semibold text-ink mb-3">Votre panier est vide</h2>
                <p class="text-ink/60 mb-8">
                    Découvrez notre collection d'ouvrages et ajoutez vos favoris.
                </p>
                <a href="{{ path('app_catalog') }}" class="btn btn-primary px-8 py-4">
                    Explorer le catalogue
                </a>
            </div>
        {% else %}
            {# Cart with Items #}
            <div class="grid lg:grid-cols-3 gap-8 lg:gap-12 items-start">
                {# Cart Items #}
                <div class="lg:col-span-2 space-y-4">
                    {% for item in cart %}
                        <article class="rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white p-4 shadow-sm transition-shadow duration-200 hover:shadow-md sm:p-6">
                            <div class="flex gap-4 sm:gap-6">
                                {# Cover #}
                                <div class="flex-shrink-0 w-20 h-28 sm:w-24 sm:h-32 rounded-lg overflow-hidden bg-cream">
                                    {% if item.book.coverImage %}
                                        <img src="{{ item.book.coverImage }}" alt="{{ item.book.title }}" loading="lazy" decoding="async" referrerpolicy="no-referrer" class="w-full h-full object-cover">
                                    {% else %}
                                        <div class="w-full h-full flex items-center justify-center text-ink/20">
                                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                                            </svg>
                                        </div>
                                    {% endif %}
                                </div>

                                {# Details #}
                                <div class="flex-1 min-w-0">
                                    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                                        {# Info #}
                                        <div class="flex-1 min-w-0">
                                            <h3 class="font-display text-lg font-semibold text-ink mb-1 truncate">
                                                <a href="{{ path('app_book_show', {slug: item.book.slug}) }}" class="hover:text-gold transition-colors">
                                                    {{ item.book.title }}
                                                </a>
                                            </h3>
                                            <p class="text-sm text-ink/50 mb-1">{{ item.book.authorsNames }}</p>
                                            <p class="text-xs text-ink/40">{{ (item.book.priceCents / 100)|number_format(2, ',', ' ') }} € / unité</p>
                                        </div>

                                        {# Price #}
                                        <div class="font-display text-xl font-semibold text-ink sm:text-right">
                                            {{ ((item.book.priceCents * item.quantity) / 100)|number_format(2, ',', ' ') }} €
                                        </div>
                                    </div>

                                    {# Actions #}
                                    <div class="flex items-center justify-between mt-4 pt-4 border-t border-black/5">
                                        {# Quantity #}
                                        <div class="flex items-center rounded-xl border border-black/10 overflow-hidden">
                                            <form action="{{ path('app_cart_decrement', {id: item.book.id}) }}" method="post">
                                                <button type="submit" class="w-10 h-10 flex items-center justify-center text-ink hover:bg-cream transition-colors" aria-label="Diminuer">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                                        <line x1="5" y1="12" x2="19" y2="12"/>
                                                    </svg>
                                                </button>
                                            </form>
                                            <span class="w-12 text-center font-semibold text-ink border-x border-black/10">{{ item.quantity }}</span>
                                            <form action="{{ path('app_cart_increment', {id: item.book.id}) }}" method="post">
                                                <button type="submit" class="w-10 h-10 flex items-center justify-center text-ink hover:bg-cream transition-colors" aria-label="Augmenter">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                                        <line x1="12" y1="5" x2="12" y2="19"/>
                                                        <line x1="5" y1="12" x2="19" y2="12"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>

                                        {# Remove #}
                                        <form action="{{ path('app_cart_remove', {id: item.book.id}) }}" method="post">
                                            <button type="submit" class="flex items-center gap-2 px-3 py-2 text-sm text-ink/50 hover:text-wine transition-colors" aria-label="Supprimer">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6"/>
                                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                                </svg>
                                                <span class="hidden sm:inline">Supprimer</span>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>

                {# Summary Sidebar #}
                <aside class="lg:sticky lg:top-24">
                    <div class="rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white p-6 shadow-sm">
                        <h2 class="font-display text-xl font-semibold text-ink mb-6 pb-4 border-b border-black/5">
                            Récapitulatif
                        </h2>

                        <div class="space-y-3 mb-6">
                            <div class="flex justify-between text-sm">
                                <span class="text-ink/60">Sous-total</span>
                                <span class="text-ink">{{ total|number_format(2, ',', ' ') }} €</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-ink/60">Livraison</span>
                                <span class="text-ink/40 italic">À calculer</span>
                            </div>
                        </div>

                        <div class="flex justify-between items-center py-4 border-t-2 border-ink mb-6">
                            <span class="font-semibold text-ink">Total</span>
                            <span class="font-display text-2xl font-bold text-ink">{{ total|number_format(2, ',', ' ') }} €</span>
                        </div>

                        {% if app.user %}
                            <a href="{{ path('app_checkout_information') }}" class="btn btn-gold w-full py-4 text-base mb-4">
                                <span class="inline-flex items-center justify-center gap-2 w-full">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                                        <line x1="1" y1="10" x2="23" y2="10"/>
                                    </svg>
                                    Informations de livraison
                                </span>
                            </a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-gold w-full py-4 text-base mb-4">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                                Se connecter pour commander
                            </a>
                        {% endif %}

                        <a href="{{ path('app_catalog') }}" class="flex items-center justify-center gap-2 text-sm text-ink/50 hover:text-ink transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <polyline points="15 18 9 12 15 6"/>
                            </svg>
                            Continuer les achats
                        </a>
                    </div>

                    {# Reassurance #}
                    <div class="mt-6 space-y-3">
                        <div class="flex items-center gap-3 text-sm text-ink/50">
                            <div class="w-10 h-10 rounded-xl bg-sage/10 flex items-center justify-center text-sage">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </div>
                            <span>Paiement 100% sécurisé</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm text-ink/50">
                            <div class="w-10 h-10 rounded-xl bg-sage/10 flex items-center justify-center text-sage">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                </svg>
                            </div>
                            <span>Données protégées</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm text-ink/50">
                            <div class="w-10 h-10 rounded-xl bg-sage/10 flex items-center justify-center text-sage">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                    <rect x="1" y="3" width="15" height="13"/>
                                    <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                                    <circle cx="5.5" cy="18.5" r="2.5"/>
                                    <circle cx="18.5" cy="18.5" r="2.5"/>
                                </svg>
                            </div>
                            <span>Livraison rapide et soignée</span>
                        </div>
                    </div>
                </aside>
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
