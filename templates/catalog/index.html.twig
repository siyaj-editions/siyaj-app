{% extends 'base.html.twig' %}

{% block title %}Catalogue - SIYAJ Éditions{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .catalog-book-card {
            border: 1px solid rgba(17, 24, 39, 0.08);
            box-shadow: 0 6px 16px rgba(17, 24, 39, 0.06);
            background: #fff;
        }

        @media (max-width: 639px) {
            .mobile-book-meta {
                padding-left: 10px;
                padding-bottom: 5px;
            }

            .mobile-book-price {
                flex-shrink: 0;
                font-size: 0.95rem;
                line-height: 1;
            }

            .shrink-0{
                padding-right: 5px;
            }

            .mobile-book-add {
                width: 1.5rem;
                height: 1.5rem;
            }

            .mobile-book-add svg {
                width: 0.75rem;
                height: 0.75rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
{# Header #}
<section class="bg-gradient-to-br from-paper to-cream py-16 lg:py-20">
    <div class="container text-center">
        <span class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-gold mb-3">
            Notre collection
        </span>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold text-ink mb-4">
            Catalogue
        </h1>
        <p class="text-lg text-ink/60 max-w-2xl mx-auto">
            Explorez notre sélection d'ouvrages littéraires
        </p>
    </div>
</section>

{# Main Content #}
<section class="py-12 lg:py-16">
    <div class="container">
        {# Filters #}
        <div class="mb-5 rounded-[28px] border border-black/5 bg-white p-4 shadow-[0_14px_40px_rgba(17,24,39,0.05)]">
            <form method="get" class="space-y-4" id="catalog-search-form">
                <div>
                    <label for="search" class="mb-2 block text-[11px] font-semibold uppercase tracking-[0.22em] text-ink/45">
                        Recherche
                    </label>
                    <div class="flex flex-col gap-3 md:flex-row md:items-center">
                        <div class="min-w-0 flex-1">
                        <input
                            type="text"
                            name="search"
                            id="search"
                            class="w-full rounded-2xl border border-black/10 bg-paper px-4 py-3 text-sm text-ink placeholder:text-ink/35 focus:border-gold focus:outline-none focus:ring-0"
                            placeholder="Titre ou ISBN"
                            value="{{ currentSearch }}"
                        >
                        </div>

                        <div class="flex shrink-0 gap-2">
                        <button
                            type="submit"
                            class="inline-flex h-10 items-center justify-center rounded-2xl bg-ink px-4 text-sm font-medium leading-none text-white transition-colors duration-200 hover:bg-gold"
                        >
                            Rechercher
                        </button>
                        <button
                            type="button"
                            class="group inline-flex h-10 cursor-pointer items-center justify-center gap-1.5 rounded-2xl border border-black/10 bg-paper px-4 text-sm font-medium leading-none text-ink transition-colors duration-200 hover:border-gold hover:bg-cream"
                            data-filter-open
                        >
                            <svg class="h-4 w-4 text-ink/55 transition-all duration-200 group-hover:-translate-y-0.5 group-hover:scale-110 group-hover:text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M7 12h10M10 18h4" />
                            </svg>
                            Filtrer
                        </button>
                        {% if currentSearch or currentAuthor or currentFormat or currentGenre %}
                            <a href="{{ path('app_catalog') }}" class="inline-flex h-10 items-center justify-center rounded-2xl border border-black/10 px-4 text-sm font-medium leading-none text-ink/60 transition-colors duration-200 hover:border-gold hover:text-ink">
                                Réinitialiser
                            </a>
                        {% endif %}
                    </div>
                    </div>
                </div>

                {% if currentSearch or currentAuthor or currentFormat or currentGenre %}
                    <div class="flex flex-wrap items-center gap-2 border-t border-black/5 pt-1">
                        <span class="text-[11px] font-semibold uppercase tracking-[0.22em] text-ink/35">Filtres actifs</span>
                        {% if currentSearch %}
                            <span class="inline-flex rounded-full bg-cream px-3 py-1.5 text-xs font-medium text-ink">Recherche: {{ currentSearch }}</span>
                        {% endif %}
                        {% if currentAuthor %}
                            {% for author in authors %}
                                {% if currentAuthor == author.id %}
                                    <span class="inline-flex rounded-full bg-cream px-3 py-1.5 text-xs font-medium text-ink">Auteur: {{ author.name }}</span>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                        {% if currentFormat %}
                            <span class="inline-flex rounded-full bg-cream px-3 py-1.5 text-xs font-medium text-ink">Format: {{ currentFormat == 'physical' ? 'Physique' : 'Numérique' }}</span>
                        {% endif %}
                        {% if currentGenre %}
                            <span class="inline-flex rounded-full bg-cream px-3 py-1.5 text-xs font-medium text-ink">Genre: {{ currentGenre }}</span>
                        {% endif %}
                    </div>
                {% endif %}

                <input type="hidden" name="author" value="{{ currentAuthor }}">
                <input type="hidden" name="format" value="{{ currentFormat }}">
                <input type="hidden" name="genre" value="{{ currentGenre }}">
                <input type="hidden" name="perPage" value="{{ perPage }}">
            </form>
        </div>

        <div
            class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/55 px-4 backdrop-blur-sm"
            data-filter-modal
            aria-hidden="true"
        >
            <div class="w-full max-w-xl rounded-[28px] border border-black/5 bg-white shadow-[0_24px_70px_rgba(17,24,39,0.18)]">
                <form method="get" class="space-y-0">
                    <input type="hidden" name="search" value="{{ currentSearch }}">
                    <input type="hidden" name="perPage" value="{{ perPage }}">
                    <div class="flex items-start justify-between gap-4 border-b border-black/5 px-6 py-5 sm:px-7">
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.26em] text-gold">Catalogue</p>
                            <h2 class="mt-2 font-display text-2xl text-ink">Filtrer les ouvrages</h2>
                            <p class="mt-2 text-sm text-ink/55">Sélectionne simplement les critères à appliquer.</p>
                        </div>
                        <button
                            type="button"
                            class="group inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-black/10 text-ink/55 transition-colors duration-200 hover:border-gold hover:text-ink"
                            data-filter-close
                            aria-label="Fermer"
                        >
                            <svg class="h-5 w-5 transition-transform duration-200 group-hover:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6l-12 12" />
                            </svg>
                        </button>
                    </div>

                    <div class="space-y-4 px-6 py-6 sm:px-7">
                        <div class="rounded-2xl border border-black/5 bg-paper/60 p-4">
                            <label for="modal-author" class="mb-2 block text-[11px] font-semibold uppercase tracking-[0.22em] text-ink/40">
                                Auteur
                            </label>
                            <select name="author" id="modal-author" class="w-full cursor-pointer rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm text-ink focus:border-gold focus:outline-none focus:ring-0">
                                <option value="">Tous les auteurs</option>
                                {% for author in authors %}
                                    <option value="{{ author.id }}" {% if currentAuthor == author.id %} selected {% endif %}>
                                        {{ author.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <!--<div class="rounded-2xl border border-black/5 bg-paper/60 p-4">
                            <label for="modal-format" class="mb-2 block text-[11px] font-semibold uppercase tracking-[0.22em] text-ink/40">
                                Format
                            </label>
                            <select name="format" id="modal-format" class="w-full cursor-pointer rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm text-ink focus:border-gold focus:outline-none focus:ring-0">
                                <option value="">Tous les formats</option>
                                <option value="physical" {% if currentFormat == 'physical' %} selected {% endif %}>Physique</option>
                                <option value="digital" {% if currentFormat == 'digital' %} selected {% endif %}>Numérique</option>
                            </select>
                        </div>-->

                        <div class="rounded-2xl border border-black/5 bg-paper/60 p-4">
                            <label for="modal-genre" class="mb-2 block text-[11px] font-semibold uppercase tracking-[0.22em] text-ink/40">
                                Genre
                            </label>
                            <select name="genre" id="modal-genre" class="w-full cursor-pointer rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm text-ink focus:border-gold focus:outline-none focus:ring-0">
                                <option value="">Tous les genres</option>
                                {% for genre in genres %}
                                    <option value="{{ genre.name }}" {% if currentGenre == genre.name %} selected {% endif %}>{{ genre.name }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="flex flex-col gap-3 border-t border-black/5 pt-6 sm:flex-row sm:items-center sm:justify-between">
                            <a href="{{ path('app_catalog', {search: currentSearch, perPage: perPage}) }}" class="inline-flex items-center justify-center rounded-2xl border border-black/10 px-4 py-2.5 text-sm font-medium text-ink/60 transition-colors duration-200 hover:border-gold hover:text-ink">
                                Effacer les filtres
                            </a>
                            <div class="flex flex-col gap-3 sm:flex-row">
                                <button type="button" class="btn btn-secondary px-4 py-2.5" data-filter-close>Annuler</button>
                                <button type="submit" class="group inline-flex cursor-pointer items-center justify-center gap-2 rounded-2xl bg-ink px-4 py-2.5 text-sm font-medium text-white transition-all duration-200 hover:bg-gold">
                                    <span>Appliquer</span>
                                    <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        {# Results Header #}
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6 pb-4 border-b border-black/5">
            <p class="text-sm text-ink/70">
                <span class="font-semibold text-ink">{{ totalBooks }}</span> ouvrage{% if totalBooks > 1 %}s{% endif %} trouvé{% if totalBooks > 1 %}s{% endif %}
            </p>
            <div class="flex flex-wrap sm:flex-nowrap items-center gap-3 sm:gap-4 w-full sm:w-auto">
                {% if totalPages > 1 %}
                    <span class="text-sm text-ink/50">Page {{ currentPage }} sur {{ totalPages }}</span>
                {% endif %}
                <div class="flex items-center gap-2 ml-auto sm:ml-0">
                    <label for="perPageSelect" class="text-xs text-ink/50">Afficher</label>
                    <select id="perPageSelect" onchange="window.location.href=this.value" class="py-1.5 px-3 text-sm rounded-lg border border-black/10">
                        {% for option in allowedPerPage %}
                            <option value="{{ path('app_catalog', {page: 1, perPage: option, search: currentSearch, author: currentAuthor, format: currentFormat, genre: currentGenre}) }}" {% if perPage == option %} selected {% endif %}>
                                {{ option }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>

        {% if books|length > 0 %}
            {# Books Grid #}
            <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-4 lg:gap-6 mb-12">
                {% for book in books %}
                    {{ include('components/book_card.html.twig', {
                        book: book,
                        variant: 'catalog'
                    }) }}
                {% endfor %}
            </div>

            {# Pagination #}
            {% if totalPages > 1 %}
                <nav aria-label="Pagination" class="flex justify-center">
                    <ul class="flex items-center gap-1.5 flex-wrap justify-center">
                        {# Previous #}
                        <li>
                            <a href="{{ path('app_catalog', {page: currentPage - 1, perPage: perPage, search: currentSearch, author: currentAuthor, format: currentFormat, genre: currentGenre}) }}"
                               class="flex items-center gap-1.5 px-4 py-2.5 text-sm font-medium rounded-xl border border-black/10 transition-all duration-200 {% if currentPage == 1 %}opacity-40 pointer-events-none{% else %}hover:bg-cream hover:border-gold text-ink{% endif %}">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <polyline points="15 18 9 12 15 6"/>
                                </svg>
                                <span class="hidden sm:inline">Précédent</span>
                            </a>
                        </li>

                        {# Page Numbers #}
                        {% set startPage = max(1, currentPage - 2) %}
                        {% set endPage = min(totalPages, currentPage + 2) %}

                        {% if startPage > 1 %}
                            <li>
                                <a href="{{ path('app_catalog', {page: 1, perPage: perPage, search: currentSearch, author: currentAuthor, format: currentFormat, genre: currentGenre}) }}"
                                   class="w-10 h-10 flex items-center justify-center text-sm font-medium rounded-xl border border-black/10 hover:bg-cream hover:border-gold text-ink transition-all duration-200">
                                    1
                                </a>
                            </li>
                            {% if startPage > 2 %}
                                <li class="px-1 text-ink/30">...</li>
                            {% endif %}
                        {% endif %}

                        {% for p in startPage..endPage %}
                            <li>
                                <a href="{{ path('app_catalog', {page: p, perPage: perPage, search: currentSearch, author: currentAuthor, format: currentFormat, genre: currentGenre}) }}"
                                   class="w-10 h-10 flex items-center justify-center text-sm font-medium rounded-xl border transition-all duration-200
                                   {% if p == currentPage %}bg-ink text-white border-ink{% else %}border-black/10 hover:bg-cream hover:border-gold text-ink{% endif %}">
                                    {{ p }}
                                </a>
                            </li>
                        {% endfor %}

                        {% if endPage < totalPages %}
                            {% if endPage < totalPages - 1 %}
                                <li class="px-1 text-ink/30">...</li>
                            {% endif %}
                            <li>
                                <a href="{{ path('app_catalog', {page: totalPages, perPage: perPage, search: currentSearch, author: currentAuthor, format: currentFormat, genre: currentGenre}) }}"
                                   class="w-10 h-10 flex items-center justify-center text-sm font-medium rounded-xl border border-black/10 hover:bg-cream hover:border-gold text-ink transition-all duration-200">
                                    {{ totalPages }}
                                </a>
                            </li>
                        {% endif %}

                        {# Next #}
                        <li>
                            <a href="{{ path('app_catalog', {page: currentPage + 1, perPage: perPage, search: currentSearch, author: currentAuthor, format: currentFormat, genre: currentGenre}) }}"
                               class="flex items-center gap-1.5 px-4 py-2.5 text-sm font-medium rounded-xl border border-black/10 transition-all duration-200 {% if currentPage == totalPages %}opacity-40 pointer-events-none{% else %}hover:bg-cream hover:border-gold text-ink{% endif %}">
                                <span class="hidden sm:inline">Suivant</span>
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <polyline points="9 18 15 12 9 6"/>
                                </svg>
                            </a>
                        </li>
                    </ul>
                </nav>
            {% endif %}

        {% else %}
            {# Empty State #}
            <div class="text-center py-20">
                <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-cream flex items-center justify-center text-ink/20">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="m21 21-4.35-4.35"/>
                    </svg>
                </div>
                <h3 class="font-display text-2xl font-semibold text-ink mb-2">Aucun ouvrage trouvé</h3>
                <p class="text-ink/60 mb-6 max-w-md mx-auto">
                    Essayez de modifier vos critères de recherche.
                </p>
                <a href="{{ path('app_catalog') }}" class="btn btn-secondary px-6 py-3">
                    Voir tout le catalogue
                </a>
            </div>
        {% endif %}
    </div>
</section>
<script>
    (() => {
        const modal = document.querySelector('[data-filter-modal]');
        const openButton = document.querySelector('[data-filter-open]');
        const closeButtons = document.querySelectorAll('[data-filter-close]');

        if (!modal || !openButton) {
            return;
        }

        const openModal = () => {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.classList.add('overflow-hidden');
        };

        const closeModal = () => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.classList.remove('overflow-hidden');
        };

        openButton.addEventListener('click', openModal);
        closeButtons.forEach((button) => button.addEventListener('click', closeModal));

        modal.addEventListener('click', (event) => {
            if (event.target === modal) {
                closeModal();
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
                closeModal();
            }
        });
    })();
</script>
{% endblock %}
