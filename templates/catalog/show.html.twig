{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} - SIYAJ{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .book-shell {
            --book-blue: #061BB0;
            --book-blue-soft: #0C4EDD;
            --book-orange: #EB5A27;
            --book-gold: #8B6B2E;
            --book-cream: #F7F4ED;
            --book-title: 'Cormorant Garamond', Georgia, serif;
            --book-body: 'Outfit', system-ui, sans-serif;
            background: var(--book-cream);
            color: var(--book-blue);
        }

        .book-shell h1,
        .book-shell h2,
        .book-shell h3 {
            font-family: var(--book-title);
        }

        .book-shell p,
        .book-shell a,
        .book-shell span,
        .book-shell button {
            font-family: var(--book-body);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="book-shell">
        <section class="container py-12 lg:py-20">
            <div class="mb-8">
                <a href="{{ path('app_catalog') }}" class="inline-flex items-center gap-2 text-sm text-[rgba(6,27,176,0.6)] transition hover:text-[var(--book-orange)]">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Retour au catalogue
                </a>
            </div>

            <div class="grid gap-10 lg:grid-cols-[0.78fr_1.22fr]">
                <div>
                    <div class="sticky top-28 overflow-hidden rounded-[2.4rem] border border-[rgba(6,27,176,0.08)] bg-white p-4 shadow-2xl">
                        {% if book.coverImage %}
                            <img src="{{ book.coverImage }}" alt="{{ book.title }}" loading="lazy" decoding="async" referrerpolicy="no-referrer" class="aspect-[4/5] w-full rounded-[1.9rem] object-cover">
                        {% else %}
                            <div class="flex aspect-[4/5] items-center justify-center rounded-[1.9rem] bg-[rgba(6,27,176,0.06)] text-[rgba(6,27,176,0.24)]">
                                <svg class="h-24 w-24" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.483 9.246 5 7.5 5S4.168 5.483 3 6.253v13C4.168 18.483 5.754 18 7.5 18s3.332.483 4.5 1.253m0-13C13.168 5.483 14.754 5 16.5 5s3.332.483 4.5 1.253v13C19.832 18.483 18.246 18 16.5 18s-3.332.483-4.5 1.253"></path>
                                </svg>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <article class="rounded-[2.4rem] border border-[rgba(6,27,176,0.08)] bg-white/82 p-8 shadow-xl lg:p-10">
                    <header class="space-y-4">
                        <div class="flex flex-wrap items-center gap-3">
                            <p class="inline-flex items-center rounded-full bg-[rgba(6,27,176,0.08)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--book-blue)]">
                                {{ book.format.label }}
                            </p>
                            {% if book.genres|length > 0 %}
                                {% for genre in book.genres|slice(0, 2) %}
                                    <span class="inline-flex rounded-full border border-[rgba(6,27,176,0.1)] bg-[rgba(247,244,237,0.85)] px-4 py-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.65)]">
                                        {{ genre.name }}
                                    </span>
                                {% endfor %}
                            {% endif %}
                        </div>

                        <h1 class="text-5xl leading-[0.96] text-[var(--book-blue)] md:text-6xl">{{ book.title }}</h1>
                        <p class="text-lg text-[color:rgba(6,27,176,0.72)]">Par {{ book.authorsNames }}</p>
                    </header>

                    <div class="mt-8 grid gap-3 text-sm sm:grid-cols-2">
                        <div class="rounded-[1.4rem] bg-[rgba(247,244,237,0.9)] px-5 py-4 text-[rgba(6,27,176,0.78)]">
                            <span class="block text-[10px] font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.46)]">ISBN</span>
                            <span class="mt-2 block">{{ book.isbn ?? 'À venir' }}</span>
                        </div>
                        <div class="rounded-[1.4rem] bg-[rgba(247,244,237,0.9)] px-5 py-4 text-[rgba(6,27,176,0.78)]">
                            <span class="block text-[10px] font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.46)]">Disponibilité</span>
                            <span class="mt-2 block">{{ book.isInStock ? 'En stock' : 'Rupture' }}</span>
                        </div>
                    </div>

                    <div class="mt-8">
                        <p class="text-4xl text-[var(--book-gold)]">{{ (book.priceCents / 100)|number_format(2, ',', ' ') }} €</p>
                    </div>

                    {% if book.description %}
                        <section class="mt-10 space-y-4">
                            <h2 class="text-3xl text-[var(--book-blue)]">Description</h2>
                            <div class="max-w-none text-base leading-8 text-[color:rgba(6,27,176,0.78)]">
                                <p>{{ book.description|nl2br }}</p>
                            </div>
                        </section>
                    {% endif %}

                    <div class="mt-10">
                        {% if book.isInStock %}
                            <form action="{{ path('app_cart_add', {id: book.id}) }}" method="post">
                                <button type="submit" class="inline-flex w-full items-center justify-center rounded-full bg-[var(--book-blue-soft)] px-8 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-white shadow-lg shadow-[rgba(12,78,221,0.2)] transition hover:bg-[var(--book-blue)] sm:w-auto">
                                    Ajouter au panier
                                </button>
                            </form>
                        {% else %}
                            <button class="inline-flex w-full cursor-not-allowed items-center justify-center rounded-full bg-[rgba(6,27,176,0.08)] px-8 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-[rgba(6,27,176,0.42)] sm:w-auto" disabled>
                                Rupture de stock
                            </button>
                        {% endif %}
                    </div>
                </article>
            </div>
        </section>
    </div>
{% endblock %}
