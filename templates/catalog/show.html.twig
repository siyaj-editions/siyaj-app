{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} - SIYAG{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-4">
        {% if book.coverImage %}
            <img src="{{ book.coverImage }}" class="img-fluid rounded" alt="{{ book.title }}">
        {% else %}
            <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="height: 400px;">
                <i class="bi bi-book" style="font-size: 8rem;"></i>
            </div>
        {% endif %}
    </div>
    <div class="col-md-8">
        <h1>{{ book.title }}</h1>
        <p class="lead">Par {{ book.authorsNames }}</p>
        <p class="text-muted">ISBN: {{ book.isbn ?? 'N/A' }}</p>
        <p class="text-muted">Format: {{ book.format.label }}</p>
        <h3 class="text-primary">{{ (book.priceCents / 100)|number_format(2, ',', ' ') }} €</h3>
        
        {% if book.description %}
            <h4 class="mt-4">Description</h4>
            <p>{{ book.description }}</p>
        {% endif %}

        {% if book.isInStock %}
            <form action="{{ path('app_cart_add', {id: book.id}) }}" method="post" class="mt-4">
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-cart-plus"></i> Ajouter au panier
                </button>
            </form>
        {% else %}
            <button class="btn btn-secondary btn-lg" disabled>Rupture de stock</button>
        {% endif %}
    </div>
</div>
{% endblock %}
