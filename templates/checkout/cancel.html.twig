{% extends 'base.html.twig' %}

{% block title %}Paiement annulé - SIYAJ Éditions{% endblock %}

{% block body %}
<section class="min-h-[calc(100vh-200px)] flex items-center py-16 bg-[#F7F4ED]">
    <div class="container">
        <div class="mx-auto max-w-lg rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white p-8 text-center shadow-sm animate-scale-in lg:p-12">
            {# Warning Icon #}
            <div class="w-24 h-24 mx-auto mb-8 rounded-full bg-gold/15 flex items-center justify-center">
                <svg class="w-12 h-12 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            </div>

            <span class="inline-block text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-3">
                Paiement non effectué
            </span>

            <h1 class="font-display text-3xl lg:text-4xl font-semibold text-ink mb-4">
                Paiement annulé
            </h1>

            <p class="text-ink/60 leading-relaxed mb-8">
                Votre paiement a été annulé. Votre panier a été conservé et vous pouvez
                reprendre votre commande à tout moment.
            </p>

            {# Actions #}
            <div class="space-y-3 mb-8">
                <a href="{{ path('app_cart') }}" class="btn btn-primary w-full py-4">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                    </svg>
                    Retour au panier
                </a>
                <a href="{{ path('app_catalog') }}" class="btn btn-secondary w-full py-4">
                    Continuer les achats
                </a>
            </div>

            {# Help #}
            <div class="pt-6 border-t border-black/5">
                <p class="text-sm text-ink/40 mb-1">Un problème avec le paiement ?</p>
                <a href="mailto:{{ contact_email }}" class="text-sm text-gold hover:text-ink underline transition-colors">
                    Contactez-nous
                </a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
