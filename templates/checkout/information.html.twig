{% extends 'base.html.twig' %}

{% block title %}Informations de commande - SIYAJ Éditions{% endblock %}

{% block body %}
<section class="bg-gradient-to-br from-paper to-cream py-10 lg:py-14">
    <div class="container">
        <h1 class="font-display text-3xl sm:text-4xl text-ink">Livraison et facturation</h1>
        <p class="text-ink/60 mt-2">Complétez vos informations avant le paiement Stripe.</p>
    </div>
</section>

<section class="py-10 lg:py-14">
    <div class="container">
        <div class="grid lg:grid-cols-3 gap-8 items-start">
            <div class="lg:col-span-2">
                <div class="card p-6 lg:p-8">
                    {{ form_start(checkoutForm, {'attr': {'class': 'space-y-8', 'id': 'checkout-form'}}) }}

                    <div class="space-y-4">
                        <h2 class="font-display text-2xl text-ink">Sélectionnez votre adresse de livraison</h2>
                        <div>
                            {{ form_label(checkoutForm.shippingAddressId, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(checkoutForm.shippingAddressId, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(checkoutForm.shippingAddressId) }}
                        </div>
                    </div>

                    <div class="space-y-4 pt-6 border-t border-black/5">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <h2 class="font-display text-2xl text-ink">Choisissez votre mode de livraison</h2>
                                <p class="text-sm text-ink/60 mt-2">
                                    Zone détectée :
                                    <span class="font-medium text-ink" id="shipping-zone-label">-</span>
                                </p>
                            </div>
                            <div class="text-right">
                                <p class="text-xs font-semibold uppercase tracking-wider text-ink/40">Délai estimé</p>
                                <p class="text-sm text-ink" id="shipping-delay-label">-</p>
                            </div>
                        </div>

                        <div class="space-y-3" id="shipping-methods">
                            {% for child in checkoutForm.shippingMethod %}
                                <label class="block rounded-2xl border border-black/10 p-4 bg-paper/80 transition-all duration-200 has-[:checked]:border-gold has-[:checked]:bg-cream" data-shipping-method-card="{{ child.vars.value }}">
                                    <div class="flex items-start gap-3">
                                        {{ form_widget(child, {'attr': {'class': 'mt-1 w-4 h-4 text-gold border-black/20 focus:ring-gold'}}) }}
                                        <div class="flex-1">
                                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                                                <div>
                                                    <p class="font-semibold text-ink">{{ child.vars.label }}</p>
                                                    <p class="text-sm text-ink/60" data-shipping-delay-for="{{ child.vars.value }}">-</p>
                                                </div>
                                                <p class="font-display text-xl text-ink" data-shipping-price-for="{{ child.vars.value }}">-</p>
                                            </div>
                                        </div>
                                    </div>
                                </label>
                            {% endfor %}
                        </div>
                        {{ form_errors(checkoutForm.shippingMethod) }}
                    </div>

                    <div class="space-y-4 pt-6 border-t border-black/5">
                        <div class="flex items-center gap-3">
                            {{ form_widget(checkoutForm.billingSameAsShipping, {'attr': {'class': 'w-5 h-5 rounded border-black/20'}}) }}
                            {{ form_label(checkoutForm.billingSameAsShipping, null, {'label_attr': {'class': 'text-sm text-ink/70'}}) }}
                        </div>

                        <div id="billing-fields" class="space-y-4 hidden">
                            <h2 class="font-display text-2xl text-ink">Sélectionnez votre adresse de facturation</h2>
                            <div>
                                {{ form_label(checkoutForm.billingAddressId, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                                {{ form_widget(checkoutForm.billingAddressId, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                                {{ form_errors(checkoutForm.billingAddressId) }}
                            </div>
                        </div>
                    </div>

                    <div class="pt-6 border-t border-black/5">
                        <p class="text-sm text-ink/60">
                            Besoin d'ajouter une nouvelle adresse ?
                            <a href="{{ path('app_account_address') }}" class="text-gold hover:underline">Gérer mes adresses</a>
                        </p>
                    </div>

                    <div class="pt-6 border-t border-black/5">
                        <button type="submit" class="btn btn-primary w-full sm:w-auto px-8 py-4">Continuer vers le paiement</button>
                    </div>
                    {{ form_end(checkoutForm) }}
                </div>
            </div>

            <aside class="lg:sticky lg:top-24">
                <div class="card p-6">
                    <h3 class="font-display text-xl text-ink mb-4">Récapitulatif</h3>
                    <div class="mb-4 p-4 rounded-xl bg-paper border border-black/5">
                        <p class="text-xs font-semibold uppercase tracking-wider text-ink/40 mb-2">Adresses disponibles</p>
                        <div class="space-y-2 text-xs text-ink/70">
                            {% for address in addresses %}
                                <p>{{ address.fullName }} - {{ address.inline }}</p>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="space-y-2 text-sm text-ink/70">
                        {% for item in cart %}
                            <div class="flex justify-between gap-3">
                                <span>{{ item.book.title }} x{{ item.quantity }}</span>
                                <span>{{ ((item.book.priceCents * item.quantity) / 100)|number_format(2, ',', ' ') }} €</span>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="mt-4 pt-4 border-t border-black/10 space-y-2 text-sm">
                        <div class="flex justify-between gap-3">
                            <span class="text-ink/60">Sous-total</span>
                            <span class="text-ink">{{ total|number_format(2, ',', ' ') }} €</span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-ink/60">Zone</span>
                            <span class="text-ink text-right" id="summary-zone-label">-</span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-ink/60">Mode</span>
                            <span class="text-ink text-right" id="summary-method-label">-</span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-ink/60">Livraison</span>
                            <span class="text-ink" id="summary-shipping-cost">-</span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-ink/60">Délai annoncé</span>
                            <span class="text-ink text-right" id="summary-shipping-delay">-</span>
                        </div>
                    </div>
                    <div class="mt-4 pt-4 border-t border-black/10 flex justify-between items-center">
                        <span class="font-semibold text-ink">Total</span>
                        <span class="font-display text-2xl text-ink" id="summary-total">-</span>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</section>

<script>
    (function () {
        var checkbox = document.getElementById('{{ checkoutForm.billingSameAsShipping.vars.id }}');
        var billingFields = document.getElementById('billing-fields');
        var shippingAddressSelect = document.getElementById('{{ checkoutForm.shippingAddressId.vars.id }}');
        var shippingMethodInputs = document.querySelectorAll('input[name="{{ checkoutForm.shippingMethod.vars.full_name }}"]');
        var shippingPreviewMap = {{ shippingPreviewMap|json_encode|raw }};
        if (!checkbox || !billingFields || !shippingAddressSelect) return;

        var toggle = function () {
            if (checkbox.checked) {
                billingFields.classList.add('hidden');
            } else {
                billingFields.classList.remove('hidden');
            }
        };

        var formatSummary = function () {
            var addressId = shippingAddressSelect.value;
            var preview = shippingPreviewMap[addressId];
            if (!preview) {
                return;
            }

            var selectedMethod = null;
            shippingMethodInputs.forEach(function (input) {
                var card = document.querySelector('[data-shipping-method-card="' + input.value + '"]');
                var methodPreview = preview.methods[input.value];
                var available = !!methodPreview;

                if (card) {
                    card.classList.toggle('hidden', !available);
                }

                input.disabled = !available;

                if (available) {
                    document.querySelector('[data-shipping-price-for="' + input.value + '"]').textContent = methodPreview.costFormatted;
                    document.querySelector('[data-shipping-delay-for="' + input.value + '"]').textContent = methodPreview.delayLabel;
                }

                if (input.checked && available) {
                    selectedMethod = input.value;
                }
            });

            if (!selectedMethod) {
                selectedMethod = preview.defaultMethod;
                var fallbackInput = document.querySelector('input[name="{{ checkoutForm.shippingMethod.vars.full_name }}"][value="' + selectedMethod + '"]');
                if (fallbackInput) {
                    fallbackInput.checked = true;
                }
            }

            var selectedPreview = preview.methods[selectedMethod];
            if (!selectedPreview) {
                return;
            }

            document.getElementById('shipping-zone-label').textContent = preview.zoneLabel;
            document.getElementById('shipping-delay-label').textContent = selectedPreview.delayLabel;
            document.getElementById('summary-zone-label').textContent = preview.zoneLabel;
            document.getElementById('summary-method-label').textContent = selectedPreview.methodLabel;
            document.getElementById('summary-shipping-cost').textContent = selectedPreview.costFormatted;
            document.getElementById('summary-shipping-delay').textContent = selectedPreview.delayLabel;
            document.getElementById('summary-total').textContent = selectedPreview.totalFormatted;
        };

        checkbox.addEventListener('change', toggle);
        shippingAddressSelect.addEventListener('change', formatSummary);
        shippingMethodInputs.forEach(function (input) {
            input.addEventListener('change', formatSummary);
        });
        toggle();
        formatSummary();
    })();
</script>
{% endblock %}
