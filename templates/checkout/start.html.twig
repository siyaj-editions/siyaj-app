{% extends 'base.html.twig' %}

{% block title %}Redirection vers le paiement - SIYAJ Éditions{% endblock %}

{% block body %}
<section class="min-h-[calc(100vh-200px)] flex items-center py-16 bg-[#F7F4ED]">
    <div class="container">
        <div class="mx-auto max-w-md rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white p-8 text-center shadow-sm lg:p-10">
            {# Loader #}
            <div class="mb-8">
                <div class="w-14 h-14 mx-auto border-3 border-cream border-t-gold rounded-full animate-spin"></div>
            </div>

            <h1 class="font-display text-2xl font-semibold text-ink mb-3">
                Redirection vers le paiement
            </h1>
            <p class="text-ink/60 mb-8">
                Vous allez être redirigé vers notre partenaire de paiement sécurisé Stripe.
            </p>

            {# Fallback #}
            <div class="mb-6 rounded-[1.5rem] bg-[rgba(247,244,237,0.8)] p-5">
                {% if sessionUrl %}
                    <p class="text-sm text-ink/50 mb-4">
                        Si la redirection ne fonctionne pas automatiquement :
                    </p>
                    <a href="{{ sessionUrl }}" class="btn btn-primary w-full">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                            <line x1="1" y1="10" x2="23" y2="10"/>
                        </svg>
                        Accéder au paiement
                    </a>
                {% else %}
                    <p class="text-sm text-ink/50 mb-4">
                        Le lien de paiement n'est pas disponible.
                    </p>
                    <a href="{{ path('app_cart') }}" class="btn btn-secondary w-full">
                        Retour au panier
                    </a>
                {% endif %}
            </div>

            {# Error Container #}
            <div id="stripe-error" class="hidden mb-6 p-4 bg-wine/10 border border-wine/20 rounded-xl text-wine text-sm"></div>

            {# Security Badge #}
            <div class="flex items-center justify-center gap-2 text-xs text-ink/40">
                <svg class="w-4 h-4 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <span>Paiement 100% sécurisé par Stripe</span>
            </div>
        </div>
    </div>
</section>

<style>
@keyframes spin {
    to { transform: rotate(360deg); }
}
.animate-spin {
    animation: spin 1s linear infinite;
}
.border-3 {
    border-width: 3px;
}
</style>

<script src="https://js.stripe.com/v3/"></script>
<script>
    (function () {
        var fallbackUrl = {{ sessionUrl ? sessionUrl|json_encode|raw : 'null' }};
        if (fallbackUrl) {
            setTimeout(function () {
                window.location.href = fallbackUrl;
            }, 1500);
        }

        if (typeof Stripe !== 'function') {
            return;
        }

        var stripe = Stripe({{ stripePublicKey|json_encode|raw }});
        stripe.redirectToCheckout({ sessionId: {{ sessionId|json_encode|raw }} }).then(function (result) {
            if (result && result.error) {
                var el = document.getElementById('stripe-error');
                el.textContent = result.error.message || 'Erreur lors de la redirection vers Stripe.';
                el.classList.remove('hidden');
            }
        });
    })();
</script>
{% endblock %}
