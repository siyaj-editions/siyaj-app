{% extends 'base.html.twig' %}

{% block title %}Commande confirmée - SIYAJ Éditions{% endblock %}

{% block body %}
<section class="min-h-[calc(100vh-200px)] flex items-center py-16 bg-gradient-to-br from-paper to-cream">
    <div class="container">
        <div class="max-w-lg mx-auto text-center bg-white rounded-2xl p-8 lg:p-12 shadow-xl animate-scale-in">
            {# Success Icon #}
            <div class="w-24 h-24 mx-auto mb-8 rounded-full bg-sage/10 flex items-center justify-center">
                <svg class="w-12 h-12 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>

            <span class="inline-block text-xs font-semibold tracking-[0.2em] uppercase text-sage mb-3">
                Paiement réussi
            </span>

            <h1 class="font-display text-3xl lg:text-4xl font-semibold text-ink mb-4">
                Merci pour votre commande !
            </h1>

            <p class="text-ink/60 leading-relaxed mb-8">
                Votre commande a été confirmée et sera traitée dans les plus brefs délais.
                Un email de confirmation vous a été envoyé.
            </p>

            {# Order Reference #}
            <div class="inline-flex flex-col gap-1 px-8 py-4 bg-cream rounded-xl mb-8">
                <span class="text-[10px] font-semibold tracking-widest uppercase text-ink/40">
                    Numéro de commande
                </span>
                <span class="font-display text-2xl font-semibold text-ink">
                    {{ order.reference }}
                </span>
            </div>

            <div class="text-left bg-paper rounded-xl p-5 mb-8 space-y-2">
                <div class="flex justify-between gap-3 text-sm">
                    <span class="text-ink/60">Sous-total</span>
                    <span class="text-ink">{{ (order.itemsSubtotalCents / 100)|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="flex justify-between gap-3 text-sm">
                    <span class="text-ink/60">Livraison</span>
                    <span class="text-ink">{{ (order.shippingCostCents / 100)|number_format(2, ',', ' ') }} €</span>
                </div>
                {% if order.shippingMethodLabel %}
                    <div class="flex justify-between gap-3 text-sm">
                        <span class="text-ink/60">Mode</span>
                        <span class="text-ink">{{ order.shippingMethodLabel }}</span>
                    </div>
                {% endif %}
                {% if order.shippingDelayLabel %}
                    <div class="flex justify-between gap-3 text-sm">
                        <span class="text-ink/60">Délai annoncé</span>
                        <span class="text-ink">{{ order.shippingDelayLabel }}</span>
                    </div>
                {% endif %}
                <div class="flex justify-between gap-3 text-base pt-3 border-t border-black/10">
                    <span class="font-semibold text-ink">Total</span>
                    <span class="font-display text-ink">{{ (order.totalCents / 100)|number_format(2, ',', ' ') }} €</span>
                </div>
            </div>

            {# Actions #}
            <div class="space-y-3">
                <a href="{{ path('app_account_order_show', {id: order.id}) }}" class="btn btn-primary w-full py-4">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                    Voir ma commande
                </a>
                <a href="{{ path('app_account_order_invoice', {id: order.id}) }}" class="btn btn-secondary w-full py-4">
                    Editer ma facture
                </a>
                <a href="{{ path('app_catalog') }}" class="btn btn-secondary w-full py-4">
                    Continuer les achats
                </a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
