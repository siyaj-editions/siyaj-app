{% extends 'base.html.twig' %}

{% block title %}Commande confirmée - SIYAG{% endblock %}

{% block body %}
<div class="text-center">
    <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
    <h1 class="mt-4">Merci pour votre commande !</h1>
    <p class="lead">Votre commande a été confirmée avec succès.</p>
    <p>Numéro de commande : <strong>{{ order.reference }}</strong></p>
    <div class="mt-4">
        <a href="{{ path('app_account_order_show', {id: order.id}) }}" class="btn btn-primary">Voir ma commande</a>
        <a href="{{ path('app_catalog') }}" class="btn btn-secondary">Continuer les achats</a>
    </div>
</div>
{% endblock %}
