{% set variant = variant|default('catalog') %}
{% set accentColor = accentColor|default('#0C4EDD') %}
{% set showPrice = showPrice ?? (variant == 'catalog') %}
{% set showCart = showCart ?? (variant == 'catalog') %}
{% set showGenres = showGenres ?? (variant == 'catalog') %}
{% set wrapperClasses = wrapperClasses|default('') %}

{% if variant == 'home' %}
    <article class="group flex h-full flex-col rounded-[2rem] border border-[rgba(6,27,176,0.08)] bg-white px-5 py-5 shadow-[0_18px_42px_rgba(6,27,176,0.08)] transition hover:-translate-y-1 {{ wrapperClasses }}">
        <div class="overflow-hidden rounded-[1.6rem] bg-[rgba(247,244,237,0.95)]">
            {% if book.coverImage %}
                <img
                    src="{{ book.coverImage }}"
                    alt="{{ book.title }}"
                    class="h-[18rem] w-full object-contain object-center transition-transform duration-500 group-hover:scale-[1.03]"
                    style="background:rgba(247,244,237,0.95);"
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                >
            {% else %}
                <div class="h-[18rem] w-full" style="background-color: {{ accentColor }};"></div>
            {% endif %}
        </div>

        <div class="flex flex-1 flex-col">
            <h3 class="mt-5 text-[#061BB0]" style="font-family:var(--font-display);font-size:2rem;line-height:1.02;">
                {{ book.title }}
            </h3>
            <p class="mt-3 text-[#5E74E9]" style="font-size:0.98rem;line-height:1.75;">
                {{ book.authorsNames ?: 'Voix éditoriale SIYAJ' }}
                {% if book.genresNames %}
                    · {{ book.genresNames }}
                {% else %}
                    · {{ book.format.label }}
                {% endif %}
            </p>

            <a href="{{ path('app_book_show', {slug: book.slug}) }}" class="mt-auto pt-6 inline-block text-sm font-semibold uppercase tracking-[0.14em] text-[#EB5A27]">
                Voir l'ouvrage →
            </a>
        </div>
    </article>
{% else %}
    <article class="group {{ wrapperClasses }}">
        <div class="card catalog-book-card h-full flex flex-col">
            <div class="relative aspect-book overflow-hidden bg-cream">
                {% if book.coverImage %}
                    <img
                        src="{{ book.coverImage }}"
                        alt="{{ book.title }}"
                        loading="lazy"
                        decoding="async"
                        referrerpolicy="no-referrer"
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    >
                {% else %}
                    <div class="w-full h-full p-4 bg-white">
                        <div class="w-full h-full rounded-[1.25rem]" style="background-color:#F59A16;"></div>
                    </div>
                {% endif %}

                {% if book.format.value == 'digital' %}
                    <span class="absolute top-3 left-3 z-10 rounded-md bg-ink px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-white">
                        Numérique
                    </span>
                {% endif %}

                <div class="absolute inset-0 flex items-center justify-center bg-ink/60 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                    <a href="{{ path('app_book_show', {slug: book.slug}) }}" class="btn btn-gold px-5 py-2.5 text-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                        Découvrir
                    </a>
                </div>
            </div>

            <div class="p-3 sm:p-4 lg:p-5 flex flex-col flex-1">
                <h3 class="font-display text-base lg:text-lg font-semibold text-ink mb-1 line-clamp-2 group-hover:text-gold transition-colors duration-200">
                    <a href="{{ path('app_book_show', {slug: book.slug}) }}">
                        {{ book.title }}
                    </a>
                </h3>
                <p class="text-xs lg:text-sm text-ink/50 mb-3 lg:mb-4 line-clamp-1">{{ book.authorsNames }}</p>

                {% if showGenres and book.genres|length > 0 %}
                    <div class="mb-3 flex flex-wrap gap-1.5">
                        {% for genre in book.genres|slice(0, 2) %}
                            <span class="inline-flex rounded-full bg-cream px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-ink/60">
                                {{ genre.name }}
                            </span>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if showPrice or showCart %}
                    <div class="mobile-book-meta mt-auto pt-3 lg:pt-4 border-t border-black/5 flex items-center justify-between gap-2 sm:px-0 sm:pb-0">
                        {% if showPrice %}
                            <span class="mobile-book-price font-display text-sm sm:text-base lg:text-xl font-semibold text-ink">
                                {{ (book.priceCents / 100)|number_format(2, ',', ' ') }} €
                            </span>
                        {% endif %}

                        {% if showCart %}
                            {% if book.isInStock %}
                                <form action="{{ path('app_cart_add', {id: book.id}) }}" method="post" class="shrink-0">
                                    <button type="submit" class="mobile-book-add sm:w-9 sm:h-9 lg:w-10 lg:h-10 rounded-full border-2 border-ink text-ink hover:bg-ink hover:text-white flex items-center justify-center transition-all duration-200" title="Ajouter au panier">
                                        <svg class="sm:w-4 sm:h-4 lg:w-5 lg:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                                        </svg>
                                    </button>
                                </form>
                            {% else %}
                                <span class="text-[10px] lg:text-xs font-medium text-ink/40 uppercase tracking-wider">
                                    Indisponible
                                </span>
                            {% endif %}
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
    </article>
{% endif %}
