{% extends 'base.html.twig' %}

{% block title %}Contact - SIYAJ Éditions{% endblock %}
{% block meta_description %}Contactez SIYAJ Éditions pour toute demande liée à la communication, aux relations publiques ou à la maison d’édition.{% endblock %}
{% block meta_image %}{{ absolute_url(asset('images/contact/contact-owner-hero.jpg')) }}{% endblock %}

{% block body %}
    <div style="background:#F7F4ED;color:#061BB0;">
        <div class="contact-owner-shell mx-auto px-4 pb-6 pt-0 md:px-6 md:pb-10 md:pt-0">
            <section class="contact-owner-hero-bleed overflow-hidden shadow-[0_18px_42px_rgba(6,27,176,0.12)]" style="border-radius:2.4rem;">
                <div class="contact-owner-hero relative overflow-hidden px-6 py-8 text-center md:px-8 md:py-10">
                    <img
                        src="{{ asset('images/contact/contact-owner-hero.jpg') }}"
                        alt="Univers végétal de SIYAJ Éditions"
                        class="absolute inset-0 h-full w-full object-cover"
                        loading="eager"
                        decoding="async"
                    >
                    <div class="contact-owner-hero-content relative z-10 flex flex-col items-center justify-center">
                        <h1 class="contact-owner-hero-title mt-2 text-[#EB5A27]" style="font-family: var(--font-display);font-size:3rem;line-height:0.95;">
                            Nous écrire
                        </h1>

                        <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
                            <a href="#contact-form" class="inline-flex items-center justify-center rounded-full bg-[#0C4EDD] px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-[#061BB0]">
                                Envoyer un message
                            </a>
                            <a href="{{ path('app_author_manuscript_submit') }}" class="inline-flex items-center justify-center rounded-full border border-white/40 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-white hover:text-[#061BB0]">
                                Soumettre un manuscrit
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="px-2 py-8">
                <div class="contact-owner-grid-2">
                    <div>
                        <p class="text-[#EB5A27]" style="font-size:1.6rem;line-height:1.15;font-weight:700;">
                            Une question en relations publiques,<br>communication ou médias ?
                        </p>
                        <p class="mt-4 text-[rgba(122,127,208,0.85)]" style="font-family:var(--font-display);font-size:1.05rem;line-height:1.35;">
                            Nous lisons chaque message avec attention.
                        </p>
                        <p class="contact-owner-copy mt-5 text-[#F59A16]" style="font-size:1.05rem;line-height:1.78;font-weight:600;">
                            Écrivez-nous et nous reviendrons vers vous rapidement. Pour les manuscrits ou portfolios, un parcours dédié existe afin de garder un traitement clair et cohérent des soumissions.
                        </p>
                    </div>

                    <div>
                        <p class="contact-owner-copy text-[#3257ea]" style="font-size:1.05rem;line-height:1.78;">
                            Les soumissions de manuscrits ou de portfolios d’artistes se font sur la page dédiée. Cela nous permet de mieux orienter les projets, d’assurer leur bonne réception et d’offrir un cadre de réponse plus adapté.
                        </p>
                        <div class="mt-6 flex items-center justify-end gap-3">
                            <a href="{{ path('app_author_manuscript_submit') }}" class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#061BB0] underline underline-offset-4">
                                Je soumets mon manuscrit
                            </a>
                            <a href="{{ path('app_author_manuscript_submit') }}" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#F59A16] text-white">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mt-8 bg-[#1735D0] px-6 py-10 text-white shadow-[0_18px_42px_rgba(6,27,176,0.18)] md:px-8 md:py-12" style="border-radius:2.4rem;">
                <p class="contact-owner-highlight text-center" style="font-family: var(--font-display);font-size:1.6rem;line-height:1.28;">
                    Une question, une demande presse ou un besoin d’échange ? Le formulaire ci-dessous reste le canal le plus simple pour nous joindre.
                </p>

                <div class="mx-auto mt-8 max-w-xl text-center text-white/88" style="font-size:0.96rem;line-height:1.8;">
                    <p>Nous essayons de revenir rapidement vers vous.</p>
                    <p class="mt-2">Les demandes éditoriales suivent, elles, un parcours séparé pour rester bien orientées.</p>
                </div>
            </section>

            <section id="contact-form" class="contact-owner-form rounded-[2.4rem] border border-[rgba(6,27,176,0.08)] bg-white/95 px-5 py-8 shadow-[0_20px_48px_rgba(6,27,176,0.08)] md:px-8 md:py-10 lg:px-10">
                <div class="mb-8 text-center">
                    <p class="font-semibold uppercase text-[#5E74E9]" style="font-size:0.82rem;letter-spacing:0.08em;">
                        Formulaire
                    </p>
                </div>

                {{ form_start(contactForm, {'attr': {'class': 'space-y-6 contact-owner-form', 'data-controller': 'form-feedback'}}) }}
                    <div class="contact-owner-form-grid-2">
                        <div>
                            <label for="{{ contactForm.firstname.vars.id }}" class="owner-form-label">Prénom<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(contactForm.firstname, {'attr': {'placeholder': 'Prénom', 'class': 'owner-form-input'}}) }}
                            {{ form_errors(contactForm.firstname) }}
                        </div>
                        <div>
                            <label for="{{ contactForm.lastname.vars.id }}" class="owner-form-label">Nom<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(contactForm.lastname, {'attr': {'placeholder': 'Nom', 'class': 'owner-form-input'}}) }}
                            {{ form_errors(contactForm.lastname) }}
                        </div>
                    </div>

                    <div class="contact-owner-form-grid-2">
                        <div>
                            <label for="{{ contactForm.email.vars.id }}" class="owner-form-label">Email<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(contactForm.email, {'attr': {'placeholder': 'votre@email.com', 'class': 'owner-form-input'}}) }}
                            {{ form_errors(contactForm.email) }}
                        </div>
                        <div>
                            <label for="{{ contactForm.subject.vars.id }}" class="owner-form-label">Motif<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(contactForm.subject, {'attr': {'class': 'owner-form-select'}}) }}
                            {{ form_errors(contactForm.subject) }}
                        </div>
                    </div>

                    <div>
                        <label for="{{ contactForm.message.vars.id }}" class="owner-form-label">Message<span class="owner-form-asterisk">*</span></label>
                        {{ form_widget(contactForm.message, {'attr': {'placeholder': 'Décrivez votre demande...', 'class': 'owner-form-textarea'}}) }}
                        {{ form_errors(contactForm.message) }}
                    </div>

                    <div aria-hidden="true">
                        {{ form_widget(contactForm.company) }}
                    </div>

                    <div class="flex flex-col gap-3 pt-2 sm:flex-row">
                        <button type="submit" class="inline-flex items-center justify-center rounded-full bg-[#0C4EDD] px-7 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-white shadow-lg shadow-[#0C4EDD]/20 transition hover:bg-[#061BB0]">
                            Envoyer mon message
                        </button>
                        <a href="mailto:{{ contact_email }}" class="inline-flex items-center justify-center rounded-full border border-[rgba(6,27,176,0.2)] px-7 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-[#061BB0] transition hover:border-[rgba(6,27,176,0.4)] hover:bg-[rgba(255,255,255,0.55)]">
                            {{ contact_email }}
                        </a>
                    </div>
                {{ form_end(contactForm) }}
            </section>
        </div>
    </div>
{% endblock %}
