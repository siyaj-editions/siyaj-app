{% extends 'base.html.twig' %}

{% block title %}À propos - SIYAJ Éditions{% endblock %}
{% block meta_description %}Découvrez SIYAJ Éditions, première maison d’édition indépendante, féministe et décoloniale des Petites Antilles, et sa vision éditoriale tournée vers rêver, transmettre et résister.{% endblock %}
{% block meta_image %}{{ absolute_url(asset('images/about/about-owner-hero.jpg')) }}{% endblock %}

{% block body %}
    <div class="about-owner-page">
        <div class="about-owner-shell mx-auto px-4 pb-6 pt-0 md:px-6 md:pb-10 md:pt-0">
            <section class="about-owner-hero-shell about-owner-hero-bleed overflow-hidden shadow-[0_18px_42px_rgba(6,27,176,0.12)]">
                <div class="about-owner-hero relative overflow-hidden px-6 py-8 text-center md:px-8 md:py-10">
                    <img
                        src="{{ asset('images/about/about-owner-hero.jpg') }}"
                        alt="Univers végétal de Siyaj Éditions"
                        class="absolute inset-0 h-full w-full object-cover"
                        loading="eager"
                        decoding="async"
                    >
                    <div class="absolute inset-0 bg-[rgba(0,0,0,0.42)]"></div>
                    <div class="about-owner-hero-content relative z-10 flex flex-col items-center justify-center">
                        <h1 class="about-owner-hero-title about-owner-hero-title-base mt-2 text-[#EB5A27]">
                            <span style="color: #F59A16;">Rêver </span> & résister
                        </h1>

                        <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
                            <a href="{{ path('app_catalog') }}" class="inline-flex items-center justify-center rounded-full bg-[#0C4EDD] px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-[#061BB0]">
                                Notre sélection
                            </a>
                            <a href="{{ path('app_contact') }}" class="inline-flex items-center justify-center rounded-full border border-white/40 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-white hover:text-[#061BB0]">
                                Nous contacter
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="about-owner-section px-2 py-8">
                <p class="about-owner-kicker font-semibold uppercase text-[#EB5A27]">
                    SA NOU YÉ
                </p>

                <div class="about-owner-grid-2 mt-4">
                    <div class="about-owner-copy-column">
                        <p class="about-owner-body-lg font-semibold uppercase text-[#061BB0]">
                            SIYAJ, la première maison d’édition indépendante antillaise, féministe et décoloniale, dédiée à la fiction et à la poésie contemporaines.
                        </p>
                        <p class="about-owner-body-md about-owner-body-md-warm mt-4 font-semibold leading-7 text-[#F59A16]">
                            Nous voulons publier des ouvrages pour raconter, explorer, rêver, loin des injonctions à justifier ou expliquer nos existences.
                        </p>
                    </div>

                    <div class="about-owner-tabs" data-controller="editorial-tabs">
                        <div class="editorial-tabs-nav" role="tablist" aria-label="Vision éditoriale Siyaj">
                            <button
                                type="button"
                                class="editorial-tab-button is-active"
                                data-editorial-tabs-target="tab"
                                data-editorial-tabs-key-param="rever"
                                data-editorial-tabs-index-param="0"
                                data-action="click->editorial-tabs#show"
                                aria-pressed="true"
                            >
                                Rêver
                            </button>
                            <button
                                type="button"
                                class="editorial-tab-button"
                                data-editorial-tabs-target="tab"
                                data-editorial-tabs-key-param="transmettre"
                                data-editorial-tabs-index-param="1"
                                data-action="click->editorial-tabs#show"
                                aria-pressed="false"
                            >
                                Transmettre
                            </button>
                            <button
                                type="button"
                                class="editorial-tab-button"
                                data-editorial-tabs-target="tab"
                                data-editorial-tabs-key-param="resister"
                                data-editorial-tabs-index-param="2"
                                data-action="click->editorial-tabs#show"
                                aria-pressed="false"
                            >
                                Résister
                            </button>
                        </div>
                        <div class="about-owner-tab-copy editorial-tab-panel mt-4 text-[#3257ea] is-active" data-editorial-tabs-target="panel" data-key="rever">
                            <p>
                                Siyaj se veut un espace de création, de transmission et de liberté littéraire où se déploient dans leur singularité et leur multiplicité les voix silenciées des afro-descendant.e.s et leurs imaginaires.
                            </p>
                        </div>
                        <div class="about-owner-tab-copy editorial-tab-panel mt-4 text-[#3257ea]" data-editorial-tabs-target="panel" data-key="transmettre" hidden>
                            <p>
                                Siyaj est un hommage aux luttes passées, tout en imaginant les voies de demain, un lieu pour explorer et partager des récits qui touchent à l’universel à partir du singulier.
                            </p>
                            <p class="mt-4">
                                Une plateforme pour amplifier les voix et les histoires trop peu entendues dans l’espace littéraire francophone.
                            </p>
                        </div>
                        <div class="about-owner-tab-copy editorial-tab-panel mt-4 text-[#3257ea]" data-editorial-tabs-target="panel" data-key="resister" hidden>
                            <p>
                                Nous croyons que la littérature peut être un espace de résistance et de libération. Une façon d’habiter le monde et de subvertir les systèmes qui cherchent à taire nos voix et écraser nos expériences en racontant nos vies, nos joies, nos rêves et nos colère.
                            </p>
                        </div>
                        <div class="about-owner-tabs-cta mt-6 flex items-center justify-end gap-3">
                            <a href="{{ path('app_author_manuscript_submit') }}" class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#061BB0] underline underline-offset-4">
                                Je soumets mon manuscrit
                            </a>
                            <a href="{{ path('app_author_manuscript_submit') }}" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#F59A16] text-white">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="about-owner-section px-2 py-4">
                <h2 class="about-owner-section-title font-semibold uppercase text-[#EB5A27]">
                    VOS COMPLICES DU MANUSCRIT À LA PUBLICATION
                </h2>

                <div class="about-owner-grid-founders mt-6">
                    <div class="about-owner-founders-copy">
                        <p class="about-owner-note italic text-[rgba(122,127,208,0.85)]">
                            “Soutirèz : complice, entremetteur.euse.<br>Soutiré : encourager, receler, air de connivence.”
                        </p>

                        <p class="about-owner-founders-lead">
                            <span class="text-[#F59A16]">Derrière Siyaj, il y a deux femmes qui se rêvent complices et facilitatrices</span>
                            <span class="text-[#5E74E9]"> de l’émergence d’une littérature impertinente qui sublime nos réels et nous fournit des outils pour rêver nos futurs.</span>
                        </p>

                        <div class="flex items-center gap-4">
                            <a href="{{ path('app_catalog') }}" class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#061BB0] underline underline-offset-4">
                                Je parcours le catalogue
                            </a>
                            <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#F59A16] text-white">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6"/>
                                </svg>
                            </span>
                        </div>
                    </div>

                    <div class="about-owner-grid-cards">
                        <article class="about-owner-card overflow-hidden bg-[#F59A16] text-white">
                            <img
                                src="{{ asset('images/team/oriane-prevost.jpg') }}"
                                alt="Oriane Prévost"
                                class="about-owner-card-image w-full object-cover object-center"
                                loading="lazy"
                                decoding="async"
                            >
                            <div class="px-5 py-5 lg:px-6 lg:py-6">
                                <p class="about-owner-card-label uppercase tracking-[0.14em] text-white/75">Oriane Prévost</p>
                                <p class="about-owner-card-copy mt-3 text-white">
                                    Éditrice passionnée, j’aime les livres contemplatifs, qui explorent l’intime, ceux qui interrogent l’âme humaine et font résonner les émotions. Entre les pages de grands formats et de belles marges, je compte bien accompagner des auteurs de chez nous et d’ailleurs pour leur offrir un espace d’expression libre et exigeant.
                                </p>
                            </div>
                        </article>

                        <article class="about-owner-card overflow-hidden bg-[#EB5A27] text-white">
                            <div class="px-5 py-5 lg:px-6 lg:py-6">
                                <p class="about-owner-card-label uppercase tracking-[0.14em] text-white/75">Réjane Pacquit</p>
                                <p class="about-owner-card-copy mt-3 text-white">
                                    Artiste pluridisciplinaire et écrivaine, je suis convaincue que l’avenir des arts dans nos territoires se situe dans la création de ponts entre les disciplines mais aussi dans la visibilisation des voix minorisées et silenciées. Ma mission est d’accompagner des artistes et des auteur.ice.s dans l’élaboration de projets littéraires et artistiques qui cassent les codes et tracent de nouveaux sillons.
                                </p>
                            </div>
                            <img
                                src="{{ asset('images/team/rejane-pacquit2.jpg') }}"
                                alt="Réjane Pacquit"
                                class="about-owner-card-image-small w-full object-cover"
                                style="object-position:center 24%;"
                                loading="lazy"
                                decoding="async"
                            >
                        </article>
                    </div>
                </div>
            </section>

            <section class="about-owner-quote about-owner-quote-shell mt-8 bg-[#1735D0] px-6 py-10 text-white shadow-[0_18px_42px_rgba(6,27,176,0.18)] md:px-8 md:py-12">
                <div class="about-owner-quote-mark leading-none text-[#F5D38B]">
                    “
                </div>
                <p class="about-owner-quote-text -mt-3 text-center leading-8 text-white">
                    Vé pa, vé, on jou tout pèp ké kaskòdé.
                </p>
            </section>

            <section class="about-owner-final px-4 py-10 text-center">
                <p class="about-owner-final-title mx-auto max-w-2xl italic leading-8 text-[#5E74E9]">
                    En créole guadeloupéen, le verbe “kaskòdé” signifie “s’enfuir, sortir du système, prendre son indépendance”.
                </p>
                <p class="about-owner-final-copy mx-auto mt-6 max-w-xl leading-6 text-[#F59A16]">
                    Chez Siyaj, nous revendiquons un esprit “kaskòd” : celui d’une démarche de subversion assumée des codes et des règles, de remise en question de nos biais dans une perspective d’émancipation.
                </p>
            </section>
        </div>
    </div>
{% endblock %}
