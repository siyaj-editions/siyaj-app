{% extends 'base.html.twig' %}

{% block title %}Accueil - SIYAJ Éditions{% endblock %}

{% block body %}
    {% set featuredBooks = latestBooks|slice(0, 3) %}
    {% set accentPalette = ['#0C4EDD', '#EB5A27', '#FFA500'] %}
    <div style="background:#F7F4ED;color:#061BB0;">
        <section class="relative overflow-hidden">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,165,0,0.08),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(235,90,39,0.07),transparent_28%)]"></div>

            <div class="container relative grid min-h-[86vh] items-center gap-14 py-16 lg:grid-cols-[0.92fr_1.08fr] lg:py-24">
                <div class="max-w-2xl">
                    <p class="section-kicker mb-5">
                        Maison d'édition
                    </p>

                    <h1 class="editorial-title-xl">
                        Une littérature engagée
                        <span class="text-[#EB5A27]">pour rêver</span>
                        et résister.
                    </h1>

                    <p class="editorial-copy mt-8 max-w-xl text-lg">
                        Chez Siyaj, nous publions des romans et des ouvrages de poésie puissants issus de la littérature caribéenne contemporaine :
                        plus qu'une maison d'édition, un espace de création et de dialogue foisonnant.
                    </p>

                    <div class="mt-10 flex flex-wrap gap-4">
                        <a href="{{ path('app_catalog') }}" class="editorial-cta-primary">
                            Explorer le catalogue
                        </a>
                        <a href="#nouveautes" class="editorial-cta-secondary">
                            Découvrir les nouveautés
                        </a>
                    </div>

                    <div class="mt-12 grid gap-4 sm:grid-cols-3">
                        <div class="editorial-surface p-5">
                            <p class="section-kicker">Voix</p>
                            <p class="mt-3 text-sm leading-7 text-[rgba(6,27,176,0.8)]">Romans, poésie et récits portés par des imaginaires caribéens contemporains.</p>
                        </div>
                        <div class="editorial-surface p-5">
                            <p class="section-kicker">Ligne</p>
                            <p class="mt-3 text-sm leading-7 text-[rgba(6,27,176,0.8)]">Une maison féministe, décoloniale, exigeante et profondément littéraire.</p>
                        </div>
                        <div class="editorial-surface p-5">
                            <p class="section-kicker">Portée</p>
                            <p class="mt-3 text-sm leading-7 text-[rgba(6,27,176,0.8)]">Des ouvrages pensés pour circuler entre Guadeloupe, Martinique et le monde.</p>
                        </div>
                    </div>
                </div>

                <div class="relative flex min-h-[420px] items-center justify-center lg:min-h-[620px]">
                    <div class="relative w-full max-w-[39rem]">
                        <div class="absolute inset-0 rounded-[3rem] blur-3xl" style="background:rgba(12,78,221,0.08);"></div>
                        <div class="relative rounded-[2.8rem] border border-[rgba(6,27,176,0.1)] bg-[rgba(255,255,255,0.75)] p-4 shadow-[0_28px_54px_rgba(6,27,176,0.09)] lg:p-5">
                            <div class="relative overflow-hidden rounded-[2.2rem] p-6 lg:p-7" style="background:#061BB0;">
                                <div class="absolute inset-0" style="background:radial-gradient(circle at top right, rgba(255,165,0,0.18), transparent 34%), radial-gradient(circle at bottom left, rgba(235,90,39,0.16), transparent 36%);"></div>
                                <div class="relative grid items-end gap-6 sm:grid-cols-[0.86fr_1.14fr]">
                                    <div class="order-2 sm:order-1">
                                        <p class="text-xs uppercase tracking-[0.26em] text-white/65">Signature éditoriale</p>
                                        <p class="mt-5 text-3xl leading-[1.05] text-white sm:text-[2.55rem]" style="font-family: var(--font-display);">
                                            Des livres qui déplacent les regards, réveillent les récits et ouvrent de nouveaux espaces.
                                        </p>
                                    </div>
                                    <div class="order-1 sm:order-2">
                                        <img
                                            src="{{ asset('images/home/hero-home.jpg') }}"
                                            alt="Paysage caribéen de SIYAJ Éditions"
                                            class="h-[360px] w-full rounded-[1.8rem] object-cover object-center shadow-[0_20px_42px_rgba(0,0,0,0.16)] lg:h-[480px]"
                                            loading="eager"
                                            decoding="async"
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="absolute -bottom-6 right-4 hidden max-w-sm rounded-[2rem] bg-white px-6 py-5 shadow-[0_22px_44px_rgba(6,27,176,0.12)] lg:block">
                            <p class="text-xs uppercase tracking-[0.24em] text-[#8B6B2E]">
                                Signature
                            </p>
                            <p class="mt-3 text-sm leading-7 text-[rgba(6,27,176,0.8)]">
                                Première maison d'édition indépendante, féministe et décoloniale des Petites Antilles.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="nouveautes" class="container py-20">
            <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                <div>
                    <p class="section-kicker">Nouveautés</p>
                    <h2 class="editorial-title-lg mt-3">Dernières parutions</h2>
                </div>

                <p class="editorial-copy-soft max-w-2xl text-base">
                    Ici les mots poussent dans des sillons millénaires, sur des terres chargées d'histoire et de murmures longtemps tus.
                </p>
            </div>

            {% if featuredBooks|length > 0 %}
                <div class="grid gap-6 md:grid-cols-3">
                    {% for book in featuredBooks %}
                        {{ include('components/book_card.html.twig', {
                            book: book,
                            variant: 'home',
                            accentColor: accentPalette[loop.index0]
                        }) }}
                    {% endfor %}
                </div>
            {% else %}
                <div class="rounded-[2rem] border border-[rgba(6,27,176,0.1)] bg-white/60 p-10 text-center shadow-sm">
                    <p class="section-kicker text-center">Bientôt</p>
                    <h3 class="editorial-title-md mt-3">Les premières parutions arrivent</h3>
                    <p class="editorial-copy-soft mx-auto mt-4 max-w-2xl">
                        La collection se prépare. La homepage est déjà prête à accueillir les ouvrages dès leur publication.
                    </p>
                </div>
            {% endif %}

            <div class="mt-10">
                <a href="{{ path('app_catalog') }}" class="editorial-cta-secondary">
                    Voir tout le catalogue
                </a>
            </div>
        </section>

        <section class="container py-6">
            <div class="px-8 py-14 lg:px-14" style="background:#061BB0;color:#fff;border-radius:2.5rem;box-shadow:0 22px 42px rgba(6,27,176,0.15);">
                <p class="max-w-4xl text-3xl leading-tight md:text-4xl">
                    « Nous croyons que la littérature peut être un espace de résistance et de libération. »
                </p>
            </div>
        </section>

        <section class="container py-20">
            <div class="grid gap-6 md:grid-cols-3">
                <div class="editorial-surface p-8">
                    <div class="mb-5 h-1.5 w-14 rounded-full bg-[#FFA500]"></div>
                    <h3 class="editorial-title-md text-[2rem]">Sélection exigeante</h3>
                    <p class="editorial-copy-soft mt-4">
                        Une ligne éditoriale affirmée, au service de textes singuliers, sensibles et engagés.
                    </p>
                </div>

                <div class="editorial-surface p-8">
                    <div class="mb-5 h-1.5 w-14 rounded-full bg-[#FFA500]"></div>
                    <h3 class="editorial-title-md text-[2rem]">Passion du livre</h3>
                    <p class="editorial-copy-soft mt-4">
                        Une équipe de passionnées au service de nos littératures et de nos auteur.ice.s.
                    </p>
                </div>

                <div class="editorial-surface p-8">
                    <div class="mb-5 h-1.5 w-14 rounded-full bg-[#FFA500]"></div>
                    <h3 class="editorial-title-md text-[2rem]">Livraison soignée</h3>
                    <p class="editorial-copy-soft mt-4">
                        Expédiées dans le monde entier avec attention, plutôt que rapidement.
                    </p>
                </div>
            </div>
        </section>

        <section class="container py-20">
            <div class="grid gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:items-stretch">
                <article class="overflow-hidden rounded-[2.5rem] border border-[rgba(6,27,176,0.08)] bg-white shadow-[0_24px_54px_rgba(6,27,176,0.08)]">
                    <div class="grid h-full lg:grid-cols-[0.9fr_1.1fr]">
                        <div class="px-8 py-10 text-white lg:px-10 lg:py-12" style="background:#061BB0;">
                            <p class="text-xs uppercase tracking-[0.28em] text-white/65">Qui sommes-nous ?</p>
                            <h2 class="mt-4 text-4xl leading-none md:text-5xl" style="font-family: var(--font-display);">
                                Une maison qui pense le livre comme un espace de transmission.
                            </h2>
                            <p class="mt-6 max-w-md text-base leading-8 text-white/82">
                                Notre manifeste, notre histoire et l’esprit Kaskòd vivent sur une page dédiée plus incarnée.
                            </p>
                            <a href="{{ path('app_about') }}" class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-[#061BB0] transition hover:bg-[rgba(255,255,255,0.92)]">
                                Découvrir Siyaj
                            </a>
                        </div>
                        <div class="flex items-center px-8 py-10 lg:px-10 lg:py-12" style="background:linear-gradient(135deg,rgba(255,165,0,0.12),rgba(235,90,39,0.08));">
                            <p class="text-3xl leading-[1.14] text-[#061BB0] md:text-[2.55rem]" style="font-family: var(--font-display);">
                                Première maison d’édition indépendante, féministe et décoloniale des Petites Antilles.
                            </p>
                        </div>
                    </div>
                </article>

                <article class="rounded-[2.5rem] px-8 py-10 text-white shadow-[0_24px_54px_rgba(235,90,39,0.15)] lg:px-10 lg:py-12" style="background:#EB5A27;">
                    <p class="text-xs uppercase tracking-[0.28em] text-white/68">Soumettre un manuscrit</p>
                    <h2 class="mt-4 text-4xl leading-none md:text-5xl" style="font-family: var(--font-display);">
                        Un parcours clair pour envoyer votre projet.
                    </h2>
                    <p class="mt-6 max-w-lg text-base leading-8 text-white/88">
                        Les consignes, le formulaire et la structure de soumission sont regroupés dans un espace dédié, pensé pour rassurer et guider.
                    </p>
                    <a href="{{ path('app_author_manuscript_submit') }}" class="mt-8 inline-flex items-center justify-center rounded-full border border-white/24 px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-white hover:text-[#EB5A27]">
                        Soumettre un projet
                    </a>
                </article>
            </div>
        </section>

        <section class="mt-4 py-20 text-white" style="background:#061BB0;">
            <div class="container">
                <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
                    <div>
                        <p class="text-xs uppercase tracking-[0.28em] text-white/60">Newsletter</p>
                        <h2 class="mt-4 text-4xl md:text-5xl">Recevoir les parutions, appels et nouvelles de la maison.</h2>
                        <p class="mt-6 max-w-2xl leading-8 text-white/75">
                            La homepage change, mais on garde le lien direct avec les lectrices, lecteurs, auteurs et allié.e.s de Siyaj.
                        </p>
                    </div>

                    <div class="rounded-[2rem] border border-white/10 p-6 backdrop-blur-sm" style="background:rgba(255,255,255,0.08);">
                        {{ form_start(newsletterForm, {'attr': {'class': 'space-y-4'}}) }}
                            {{ form_widget(newsletterForm.email, {'attr': {'class': '!rounded-full !px-5 !py-4 !text-white', 'style': 'border:1px solid rgba(255,255,255,0.15);background:rgba(255,255,255,0.08);', 'placeholder': 'Votre adresse email'}}) }}
                            <div aria-hidden="true">
                                {{ form_widget(newsletterForm.company) }}
                            </div>
                            <button type="submit" class="inline-flex w-full items-center justify-center rounded-full bg-white px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] transition hover:bg-[rgba(255,255,255,0.92)]" style="color:#061BB0;">
                                S'inscrire à la newsletter
                            </button>
                        {{ form_end(newsletterForm) }}
                    </div>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
