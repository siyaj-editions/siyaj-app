{% extends 'base.html.twig' %}

{% block title %}Accueil - SIYAJ Éditions{% endblock %}
{% block meta_description %}SIYAJ Éditions est une maison d’édition indépendante, féministe et décoloniale des Petites Antilles. Découvrez notre catalogue, notre ligne éditoriale et nos nouveautés.{% endblock %}
{% block meta_image %}{{ canonical_origin|trim('/') ~ asset('images/home/hero-home.jpg') }}{% endblock %}

{% block body %}
    {% set featuredBooks = latestBooks|slice(0, 3) %}
    {% set accentPalette = ['#F59A16', '#EB5A27', '#1735D0'] %}
    <div class="home-owner-page">
        <div class="home-owner-shell mx-auto px-4 pb-6 pt-0 md:px-6 md:pb-10 md:pt-0">
            <section class="home-owner-hero-shell home-owner-hero-bleed overflow-hidden shadow-[0_18px_42px_rgba(6,27,176,0.12)]">
                <div class="home-owner-hero relative overflow-hidden px-6 py-8 md:px-8 md:py-10">
                    <img
                        src="{{ asset('images/home/hero-home.jpg') }}"
                        alt="Paysage caribéen de SIYAJ Éditions"
                        class="absolute inset-0 h-full w-full object-cover object-center"
                        style="object-position:center 44%;"
                        loading="eager"
                        decoding="async"
                    >
                    <div class="absolute inset-0 bg-[rgba(0,0,0,0.42)]"></div>
                    <div class="home-owner-hero-content home-owner-hero-layout relative z-10 flex flex-col justify-center">
                        <p class="home-owner-hero-subtitle text-white/75">
                            la maison d’édition
                        </p>
                        <h1 class="home-owner-hero-title home-owner-hero-title-base mt-2">
                            <span class="text-[#F59A16]">Une littérature engagée</span><br>
                            <span class="text-[#F59A16]">pour </span><span class="text-[#EB5A27]">rêver & résister</span>
                        </h1>

                        <p class="home-owner-hero-copy mt-5 max-w-5xl text-white/88">
                            Chez Siyaj nous publions des romans et des ouvrages de poésie puissants issus de la littérature caribéenne contemporaine : plus qu’une maison d’édition, un espace de création et de dialogue foisonnant où nos auteur.ice.s et nos artistes n’ont pas à se traduire pour se faire entendre.
                        </p>

                        <div class="mt-7 flex flex-wrap items-center gap-3">
                            <a href="{{ path('app_catalog') }}" class="inline-flex items-center justify-center rounded-full bg-[#0C4EDD] px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-[#061BB0]">
                                Découvrir le catalogue
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section id="nouveautes" class="px-2 py-4">
                <h2 class="home-owner-section-title font-semibold uppercase text-[#EB5A27]">
                    NOS NOUVEAUTÉS
                </h2>

                <div class="mt-6">
                    <p class="home-owner-display-note italic text-[rgba(122,127,208,0.85)]">
                        Des parutions qui déplacent les regards et prolongent nos conversations.
                    </p>

                    <p class="home-owner-highlight home-owner-highlight-base mt-6 max-w-8xl">
                        <span class="text-[#F59A16]">Nos livres s’inscrivent dans une ligne exigeante, sensible et engagée</span>
                        <span class="text-[#5E74E9]"> qui fait dialoguer fiction, poésie, mémoire, résistance et imaginaire caribéen contemporain.</span>
                    </p>
                </div>

                {% if featuredBooks|length > 0 %}
                    <div class="home-owner-book-grid mt-10">
                        {% for book in featuredBooks %}
                            {{ include('components/book_card.html.twig', {
                                book: book,
                                variant: 'home',
                                accentColor: accentPalette[loop.index0]
                            }) }}
                        {% endfor %}
                    </div>
                        <div class="mt-8 flex items-center gap-4">
                        <a href="{{ path('app_catalog') }}" class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#061BB0] underline underline-offset-4">
                            Voir tout le catalogue
                        </a>
                        <a href="{{ path('app_catalog') }}" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#F59A16] text-white">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6"/>
                            </svg>
                        </a>
                    </div>
                {% else %}
                    <div class="mt-10 rounded-[2rem] border border-[rgba(6,27,176,0.1)] bg-white/70 p-8 shadow-[0_18px_42px_rgba(6,27,176,0.08)]">
                        <p class="home-owner-display-note italic text-[rgba(122,127,208,0.85)]">
                            Les premières parutions arrivent.
                        </p>
                        <p class="home-owner-body-warm mt-5 text-[#5E74E9]">
                            La collection se prépare. La homepage est déjà prête à accueillir les ouvrages dès leur publication.
                        </p>
                    </div>
                {% endif %}
            </section>

            <section class="home-owner-quote-shell mt-8 bg-[#1735D0] px-6 py-10 text-white shadow-[0_18px_42px_rgba(6,27,176,0.18)] md:px-8 md:py-12">
                <div class="home-owner-quote-mark leading-none text-[#F5D38B]">
                    “
                </div>
                <p class="home-owner-quote-text -mt-3 text-center text-white">
                    Nous croyons que la littérature peut être un espace de résistance et de libération. »
                </p>
            </section>

            <section class="px-2 py-8">
                <div class="home-owner-grid-3">
                    <article class="rounded-[2rem] bg-white px-6 py-6 shadow-[0_18px_42px_rgba(6,27,176,0.08)]">
                        <div class="mb-4 h-1.5 w-14 rounded-full bg-[#F59A16]"></div>
                        <h3 class="text-[#061BB0]" style="font-family:var(--font-display);font-size:2rem;line-height:1.05;">
                            Sélection exigeante
                        </h3>
                        <p class="mt-4 text-[#5E74E9]" style="font-size:1rem;line-height:1.75;">
                            Une ligne éditoriale affirmée, au service de textes singuliers, sensibles et engagés.
                        </p>
                    </article>

                    <article class="rounded-[2rem] bg-white px-6 py-6 shadow-[0_18px_42px_rgba(6,27,176,0.08)]">
                        <div class="mb-4 h-1.5 w-14 rounded-full bg-[#F59A16]"></div>
                        <h3 class="text-[#061BB0]" style="font-family:var(--font-display);font-size:2rem;line-height:1.05;">
                            Passion du livre
                        </h3>
                        <p class="mt-4 text-[#5E74E9]" style="font-size:1rem;line-height:1.75;">
                            Une équipe investie pour accompagner les auteur.ice.s avec attention, soin et conviction.
                        </p>
                    </article>

                    <article class="rounded-[2rem] bg-white px-6 py-6 shadow-[0_18px_42px_rgba(6,27,176,0.08)]">
                        <div class="mb-4 h-1.5 w-14 rounded-full bg-[#F59A16]"></div>
                        <h3 class="text-[#061BB0]" style="font-family:var(--font-display);font-size:2rem;line-height:1.05;">
                            Livraison soignée
                        </h3>
                        <p class="mt-4 text-[#5E74E9]" style="font-size:1rem;line-height:1.75;">
                            Des ouvrages préparés avec attention et expédiés dans le monde entier.
                        </p>
                    </article>
                </div>
            </section>

            <section class="px-2 py-4">
                <div class="home-owner-grid-2">
                    <article class="overflow-hidden rounded-[2.4rem] bg-[#1735D0] text-white shadow-[0_18px_42px_rgba(6,27,176,0.16)]">
                        <div class="grid h-full">
                            <div class="px-8 py-8 lg:px-10 lg:py-10">
                                <p class="text-xs uppercase tracking-[0.26em] text-white/65">Qui sommes-nous ?</p>
                                <p class="home-owner-panel-highlight mt-4 text-white">
                                    Première maison d’édition indépendante, féministe et décoloniale des Petites Antilles.
                                </p>
                                <p class="mt-5 text-white/84" style="font-size:1rem;line-height:1.75;">
                                    Notre manifeste, notre histoire et l’esprit Kaskòd vivent sur une page dédiée plus incarnée.
                                </p>
                                <a href="{{ path('app_about') }}" class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-[#061BB0] transition hover:bg-[rgba(255,255,255,0.92)] max-width:15rem width:15rem;">
                                    Découvrir Siyaj
                                </a>
                            </div>
                        </div>
                    </article>

                    <article class="rounded-[2.4rem] bg-[#EB5A27] px-6 py-8 text-white shadow-[0_18px_42px_rgba(235,90,39,0.16)] lg:px-8 lg:py-10">
                        <p class="text-xs uppercase tracking-[0.26em] text-white/68">Soumettre un manuscrit</p>
                        <p class="mt-4 text-white" style="font-family:var(--font-display);font-size:2.15rem;line-height:1.05;">
                            Un parcours clair pour envoyer votre projet.
                        </p>
                        <p class="mt-5 text-white/88" style="font-size:1rem;line-height:1.75;">
                            Les consignes, le formulaire et la structure de soumission sont regroupés dans un espace dédié, pensé pour rassurer et guider.
                        </p>
                        <a href="{{ path('app_author_manuscript_submit') }}" class="mt-8 inline-flex items-center justify-center rounded-full border border-white/24 px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-white hover:text-[#EB5A27]">
                            Soumettre un projet
                        </a>
                    </article>
                </div>
            </section>

            <section class="mt-8 bg-[#1735D0] px-6 py-10 text-white shadow-[0_18px_42px_rgba(6,27,176,0.18)] md:px-8 md:py-12" style="border-radius:2.4rem;">
                <p class="text-xs uppercase tracking-[0.26em] text-white/64">Newsletter</p>
                <div class="home-owner-grid-2 mt-6 items-center">
                    <div>
                        <p style="font-family:var(--font-display);font-size:2.2rem;line-height:1.08;">
                            Recevoir les parutions, appels et nouvelles de la maison.
                        </p>
                        <p class="mt-5 text-white/80" style="font-size:1rem;line-height:1.75;">
                            On garde le lien direct avec les lecteur.ice.s, auteur.ice.s et allié.e.s de Siyaj.
                        </p>
                    </div>

                    <div class="rounded-[2rem] border border-white/10 p-5" style="background:rgba(255,255,255,0.08);backdrop-filter: blur(10px);">
                        {{ form_start(newsletterForm, {'attr': {'class': 'space-y-4'}}) }}
                            {{ form_widget(newsletterForm.email, {'attr': {'class': '!rounded-full !px-5 !py-4 !text-white', 'style': 'border:1px solid rgba(255,255,255,0.15);background:rgba(255,255,255,0.62);', 'placeholder': 'Votre adresse email'}}) }}
                            <div aria-hidden="true">
                                {{ form_widget(newsletterForm.company) }}
                            </div>
                            <button type="submit" class="inline-flex w-full items-center justify-center rounded-full bg-white px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] transition hover:bg-[rgba(255,255,255,0.92)]" style="color:#061BB0;">
                                S'inscrire à la newsletter
                            </button>
                        {{ form_end(newsletterForm) }}
                    </div>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
