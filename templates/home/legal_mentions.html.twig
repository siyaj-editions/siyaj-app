{% extends 'base.html.twig' %}

{% block title %}Mentions légales - SIYAJ Éditions{% endblock %}

{% block body %}
<section class="bg-gradient-to-br from-paper to-cream py-12 lg:py-16">
    <div class="container">
        <h1 class="font-display text-4xl lg:text-5xl text-ink">Mentions légales</h1>
        <p class="text-ink/60 mt-3">Informations légales relatives au site SIYAJ Éditions.</p>
    </div>
</section>

<section class="py-12 lg:py-16">
    <div class="container max-w-4xl">
        <article class="card p-7 lg:p-10 space-y-6 text-sm text-ink/80 leading-relaxed">
            <div>
                <h2 class="font-display text-2xl text-ink mb-2">Éditeur du site</h2>
                <p>SIYAJ Éditions<br>Paris, France<br>Email: contact@siyaj-editions.fr</p>
            </div>
            <div>
                <h2 class="font-display text-2xl text-ink mb-2">Directeur de la publication</h2>
                <p>Le représentant légal de SIYAJ Éditions.</p>
            </div>
            <div>
                <h2 class="font-display text-2xl text-ink mb-2">Hébergement</h2>
                <p>Le site est hébergé sur une infrastructure cloud sécurisée au sein de l’Union européenne.</p>
            </div>
            <div>
                <h2 class="font-display text-2xl text-ink mb-2">Propriété intellectuelle</h2>
                <p>L’ensemble des contenus (textes, visuels, logos, éléments graphiques) est protégé. Toute reproduction non autorisée est interdite.</p>
            </div>
            <div>
                <h2 class="font-display text-2xl text-ink mb-2">Responsabilité</h2>
                <p>SIYAJ Éditions met en œuvre tous les moyens raisonnables pour assurer la fiabilité des informations publiées, sans garantie d’absence d’erreur.</p>
            </div>
        </article>
    </div>
</section>
{% endblock %}
