{% extends 'base.html.twig' %}

{% block title %}Soumettre un manuscrit - SIYAJ Éditions{% endblock %}

{% block body %}
    <div style="background:#F7F4ED;color:#061BB0;">
        <div class="manuscript-owner-shell mx-auto px-4 pb-6 pt-0 md:px-6 md:pb-10 md:pt-0">
            <section class="manuscript-owner-hero-bleed overflow-hidden shadow-[0_18px_42px_rgba(6,27,176,0.12)]" style="border-radius:2.4rem;">
                <div class="manuscript-owner-hero relative overflow-hidden px-6 py-8 text-center md:px-8 md:py-10">
                    <img
                        src="{{ asset('images/manuscript/manuscript-owner-hero-v3.jpg') }}"
                        alt="Univers de soumission chez Siyaj Éditions"
                        class="absolute inset-0 h-full w-full object-cover"
                        loading="eager"
                        decoding="async"
                    >
                    <div class="absolute inset-0 bg-[rgba(0,0,0,0.42)]"></div>
                    <div class="manuscript-owner-hero-content relative z-10 flex flex-col items-center justify-center">
                        <h1 class="manuscript-owner-hero-title mt-2 text-[#EB5A27]" style="font-family: var(--font-display);font-size:3rem;line-height:0.95;">
                            Nous <span style="color: #F59A16;"> soumettre </span> un projet
                        </h1>

                        <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
                            <a href="#submission-form" class="inline-flex items-center justify-center rounded-full border border-white/40 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-white hover:text-[#061BB0]">
                                Soumettre un projet
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="px-2 py-8">
                <div class="manuscript-owner-grid-2">
                    <div>
                        <p class="text-[#EB5A27]" style="font-size:1.6rem;line-height:1.15;font-weight:700;">
                            Des récits incarnés,<br>une poésie engagée
                        </p>
                        <p class="mt-4 text-[rgba(122,127,208,0.85)]" style="font-family:var(--font-display);font-size:1.05rem;line-height:1.35;">
                            Notre maison, notre ligne, nos résonances.
                        </p>
                        <p class="manuscript-owner-copy mt-5 text-[#F59A16]" style="font-size:1.05rem;line-height:1.78;font-weight:600;">
                            Chez Siyaj, nous accompagnons du manuscrit à la publication des auteurs et autrices qui produisent des histoires uniques, singulières, enracinées dans des expériences trop souvent invisibilisées.
                        </p>
                    </div>

                    <div class="manuscript-owner-tabs" data-controller="editorial-tabs">
                        <div class="editorial-tabs-nav" role="tablist" aria-label="Ligne éditoriale Siyaj">
                            <button
                                type="button"
                                class="editorial-tab-button is-active"
                                data-editorial-tabs-target="tab"
                                data-editorial-tabs-key-param="raconter"
                                data-editorial-tabs-index-param="0"
                                data-action="click->editorial-tabs#show"
                                aria-pressed="true"
                            >
                                Raconter
                            </button>
                            <button
                                type="button"
                                class="editorial-tab-button"
                                data-editorial-tabs-target="tab"
                                data-editorial-tabs-key-param="celebrer"
                                data-editorial-tabs-index-param="1"
                                data-action="click->editorial-tabs#show"
                                aria-pressed="false"
                            >
                                Célébrer
                            </button>
                            <button
                                type="button"
                                class="editorial-tab-button"
                                data-editorial-tabs-target="tab"
                                data-editorial-tabs-key-param="inspirer"
                                data-editorial-tabs-index-param="2"
                                data-action="click->editorial-tabs#show"
                                aria-pressed="false"
                            >
                                Inspirer
                            </button>
                        </div>
                        <div class="manuscript-owner-copy editorial-tab-panel mt-5 leading-7 text-[#3257ea] is-active" data-editorial-tabs-target="panel" data-key="raconter" style="font-size:1.08rem;line-height:1.72;max-width:32rem;">
                            <p>
                                Nous voulons accueillir une exploration audacieuse et sensible de récits de fiction et de poésie singuliers, traversée et enrichie par les <em>gender/queer/postcolonial studies</em> et les luttes et études féministes sans jamais enfermer nos autrices et auteurs dans des catégories restrictives.
                            </p>
                        </div>
                        <div class="manuscript-owner-copy editorial-tab-panel mt-5 leading-7 text-[#3257ea]" data-editorial-tabs-target="panel" data-key="celebrer" hidden style="font-size:1.08rem;line-height:1.72;max-width:32rem;">
                            <p>
                                Nous avons la volonté de célébrer les imaginaires afro-descendants, dans toute leur diversité et leur richesse.
                            </p>
                        </div>
                        <div class="manuscript-owner-copy editorial-tab-panel mt-5 leading-7 text-[#3257ea]" data-editorial-tabs-target="panel" data-key="inspirer" hidden style="font-size:1.08rem;line-height:1.72;max-width:32rem;">
                            <p>
                                Nous recherchons des récits capables d’accueillir nos colères et de les chérir pour inspirer nos combats. Ces récits sont les vôtres et il nous tarde de les lire.
                            </p>
                        </div>
                        <div class="mt-6 flex items-center justify-end gap-3">
                            <a href="#submission-form" class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#061BB0] underline underline-offset-4">
                                Je soumets mon manuscrit
                            </a>
                            <a href="#submission-form" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#F59A16] text-white">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mt-8 bg-[#1735D0] px-6 py-10 text-white shadow-[0_18px_42px_rgba(6,27,176,0.18)] md:px-8 md:py-12" style="border-radius:2.4rem;">
                <p class="manuscript-owner-highlight text-center" style="font-family: var(--font-display);font-size:1.6rem;line-height:1.28;">
                    Bienvenue sur notre plateforme en ligne de soumissions de manuscrits. Pour nous soumettre un projet, merci de remplir le formulaire ci-dessous et d’y téléverser ton manuscrit complet.
                </p>

                <div class="mx-auto mt-8 max-w-3xl text-center text-white/88" style="font-size:0.96rem;line-height:1.8;">
                    <p>Seuls les projets aboutis et achevés seront étudiés par notre comité éditorial.</p>
                    <p class="mt-2">Nous reviendrons vers toi dans un délai ce six mois maximum.</p>
                    <p class="mt-4">Nous recherchons des récits capables d’accueillir nos colères et de les chérir pour inspirer nos combats. Ces récits sont les vôtres et il nous tarde de les lire.</p>
                </div>
            </section>

            <section id="submission-form" class="manuscript-owner-form rounded-[2.4rem] border border-[rgba(6,27,176,0.08)] bg-white/95 px-5 py-8 shadow-[0_20px_48px_rgba(6,27,176,0.08)] md:px-8 md:py-10 lg:px-10">
                <div class="mb-8 text-center">
                    <p class="font-semibold uppercase text-[#5E74E9]" style="font-size:0.82rem;letter-spacing:0.08em;">
                        Plateforme
                    </p>
                </div>

                {{ form_start(submissionForm, {'attr': {'class': 'space-y-6 manuscript-owner-form', 'data-controller': 'form-feedback'}}) }}
                    <div class="manuscript-owner-form-grid-2">
                        <div>
                            <label for="{{ submissionForm.firstname.vars.id }}" class="owner-form-label">Prénom<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(submissionForm.firstname, {'attr': {'placeholder': 'Prénom', 'class': 'owner-form-input'}}) }}
                            {{ form_errors(submissionForm.firstname) }}
                        </div>
                        <div>
                            <label for="{{ submissionForm.lastname.vars.id }}" class="owner-form-label">Nom<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(submissionForm.lastname, {'attr': {'placeholder': 'Nom', 'class': 'owner-form-input'}}) }}
                            {{ form_errors(submissionForm.lastname) }}
                        </div>
                    </div>

                    <div class="manuscript-owner-form-grid-2">
                        <div>
                            <label for="{{ submissionForm.email.vars.id }}" class="owner-form-label">Email<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(submissionForm.email, {'attr': {'placeholder': 'votre@email.com', 'class': 'owner-form-input'}}) }}
                            {{ form_errors(submissionForm.email) }}
                        </div>
                        <div>
                            <label for="{{ submissionForm.phone.vars.id }}" class="owner-form-label">Téléphone<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(submissionForm.phone, {'attr': {'placeholder': 'Téléphone', 'class': 'owner-form-input'}}) }}
                            {{ form_errors(submissionForm.phone) }}
                        </div>
                    </div>

                    <div class="manuscript-owner-form-grid-2">
                        <div>
                            <label for="{{ submissionForm.bookTitle.vars.id }}" class="owner-form-label">Titre du manuscrit<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(submissionForm.bookTitle, {'attr': {'placeholder': 'Titre du projet', 'class': 'owner-form-input'}}) }}
                            {{ form_errors(submissionForm.bookTitle) }}
                        </div>
                        <div>
                            <label for="{{ submissionForm.genre.vars.id }}" class="owner-form-label">Genre littéraire<span class="owner-form-asterisk">*</span></label>
                            {{ form_widget(submissionForm.genre, {'attr': {'class': 'owner-form-input'}}) }}
                            {{ form_errors(submissionForm.genre) }}
                        </div>
                    </div>

                    <div>
                        <label for="{{ submissionForm.synopsis.vars.id }}" class="owner-form-label">Résumé / note d’intention<span class="owner-form-asterisk">*</span></label>
                        {{ form_widget(submissionForm.synopsis, {'attr': {'placeholder': 'Présentez votre manuscrit, son intention et sa forme.', 'class': 'owner-form-textarea'}}) }}
                        {{ form_errors(submissionForm.synopsis) }}
                    </div>

                    <div>
                        <label for="{{ submissionForm.manuscriptFile.vars.id }}" class="owner-form-label">Manuscrit PDF<span class="owner-form-asterisk">*</span></label>
                        <div
                            class="manuscript-upload-zone mt-3"
                            data-controller="upload-dropzone"
                            data-upload-dropzone-target="zone"
                            data-action="click->upload-dropzone#open dragover->upload-dropzone#dragOver dragleave->upload-dropzone#dragLeave drop->upload-dropzone#drop"
                        >
                            {{ form_widget(submissionForm.manuscriptFile, {
                                'attr': {
                                    'class': 'manuscript-upload-input owner-form-input',
                                    'accept': 'application/pdf',
                                    'data-upload-dropzone-target': 'input',
                                    'data-action': 'change->upload-dropzone#updateLabel'
                                }
                            }) }}

                            <div class="flex flex-col items-start gap-4 md:flex-row md:items-center">
                                <div class="manuscript-upload-icon" aria-hidden="true">
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 16V4m0 0-4 4m4-4 4 4M4 16.5v1.75A1.75 1.75 0 0 0 5.75 20h12.5A1.75 1.75 0 0 0 20 18.25V16.5"/>
                                    </svg>
                                </div>
                                <div class="space-y-2">
                                    <p class="manuscript-upload-name" data-upload-dropzone-target="name">Glissez-déposez votre PDF ici ou cliquez pour le sélectionner</p>
                                    <p class="manuscript-upload-help">Format accepté : PDF uniquement, 20 Mo maximum.</p>
                                </div>
                            </div>
                        </div>
                        {{ form_errors(submissionForm.manuscriptFile) }}
                    </div>

                    <div class="rounded-[1.75rem] border border-dashed border-[rgba(6,27,176,0.2)] bg-[rgba(255,255,255,0.55)] px-5 py-6">
                        <p class="text-xs uppercase tracking-[0.24em] text-[#8B6B2E]">Manuscrit</p>
                        <p class="mt-3 text-sm leading-7 text-[rgba(6,27,176,0.78)]">
                            Déposez votre manuscrit directement dans la zone ci-dessus. Une fois envoyé, il sera disponible au téléchargement dans l’espace admin.
                        </p>
                    </div>

                    <div aria-hidden="true">
                        {{ form_widget(submissionForm.company) }}
                    </div>

                    <div class="flex flex-col gap-3 pt-2 sm:flex-row">
                        <button type="submit" class="inline-flex items-center justify-center rounded-full bg-[#0C4EDD] px-7 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-white shadow-lg shadow-[#0C4EDD]/20 transition hover:bg-[#061BB0]">
                            Envoyer le manuscrit
                        </button>
                        <a href="{{ path('app_about') }}" class="inline-flex items-center justify-center rounded-full border border-[rgba(6,27,176,0.2)] px-7 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-[#061BB0] transition hover:border-[rgba(6,27,176,0.4)] hover:bg-[rgba(255,255,255,0.55)]">
                            Découvrir la maison
                        </a>
                    </div>
                {{ form_end(submissionForm) }}
            </section>
        </div>
    </div>
{% endblock %}
