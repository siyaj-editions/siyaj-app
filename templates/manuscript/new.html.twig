{% extends 'base.html.twig' %}

{% block title %}Soumettre un manuscrit - SIYAJ Éditions{% endblock %}

{% block body %}
    <div class="bg-[#F7F4ED] text-[#061BB0]">
        <section class="container py-20 lg:py-24">
            <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
                <div>
                    <h1 class="editorial-title-lg">Envoyez-nous votre projet</h1>

                    <div class="editorial-copy mt-8 space-y-6 text-lg">
                        <p>Bienvenue sur notre plateforme de soumission. Merci de remplir le formulaire ci-dessous et d'y joindre les informations essentielles sur votre projet.</p>
                        <p>Seuls les projets aboutis et achevés seront étudiés par notre comité éditorial. Nous reviendrons vers vous dans un délai de six mois maximum.</p>
                        <p>Nous recherchons des récits capables d'accueillir nos colères, de nourrir nos imaginaires et d'inspirer nos combats.</p>
                    </div>

                    <div class="mt-10 overflow-hidden rounded-[2.4rem] border border-[rgba(6,27,176,0.08)] bg-white shadow-[0_24px_54px_rgba(6,27,176,0.08)]">
                        <div class="bg-[#061BB0] px-6 py-6 text-white lg:px-8">
                            <p class="text-xs uppercase tracking-[0.28em] text-white/65">Avant d’envoyer</p>
                            <p class="mt-4 text-3xl leading-[1.08]" style="font-family: var(--font-display);">
                                Un projet abouti, un synopsis clair, un lien de lecture simple.
                            </p>
                        </div>
                        <div class="px-6 py-7 lg:px-8">
                            <ul class="space-y-3 text-sm leading-7 text-[rgba(6,27,176,0.78)]">
                                <li>Le manuscrit doit être achevé.</li>
                                <li>Le synopsis doit être suffisamment précis pour situer le projet.</li>
                                <li>Le lien de lecture doit être accessible sans friction.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <section class="editorial-surface-strong p-8 lg:p-10">
                    <div class="mb-8 flex items-start justify-between gap-4 border-b border-[rgba(6,27,176,0.08)] pb-6">
                        <div>
                            <p class="section-kicker">Formulaire</p>
                            <h2 class="editorial-title-md mt-3 text-[2.5rem]">Déposer votre manuscrit</h2>
                        </div>
                        <div class="hidden rounded-full bg-[rgba(255,165,0,0.12)] px-4 py-2 text-xs uppercase tracking-[0.24em] text-[#8B6B2E] md:block">
                            Réponse sous 6 mois
                        </div>
                    </div>
                    {{ form_start(submissionForm, {'attr': {'class': 'space-y-6'}}) }}
                        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                            <div>
                                {{ form_label(submissionForm.firstname, null, {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(submissionForm.firstname) }}
                                {{ form_errors(submissionForm.firstname) }}
                            </div>
                            <div>
                                {{ form_label(submissionForm.lastname, null, {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(submissionForm.lastname) }}
                                {{ form_errors(submissionForm.lastname) }}
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                            <div>
                                {{ form_label(submissionForm.email, null, {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(submissionForm.email) }}
                                {{ form_errors(submissionForm.email) }}
                            </div>
                            <div>
                                {{ form_label(submissionForm.phone, null, {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(submissionForm.phone) }}
                                {{ form_errors(submissionForm.phone) }}
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                            <div>
                                {{ form_label(submissionForm.bookTitle, null, {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(submissionForm.bookTitle) }}
                                {{ form_errors(submissionForm.bookTitle) }}
                            </div>
                            <div>
                                {{ form_label(submissionForm.genre, null, {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(submissionForm.genre) }}
                                {{ form_errors(submissionForm.genre) }}
                            </div>
                        </div>

                        <div>
                            {{ form_label(submissionForm.synopsis, null, {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                            {{ form_widget(submissionForm.synopsis, {'attr': {'class': '!min-h-[180px]', 'placeholder': 'Présentez votre manuscrit, son intention et sa forme.'}}) }}
                            {{ form_errors(submissionForm.synopsis) }}
                        </div>

                        <div>
                            {{ form_label(submissionForm.manuscriptUrl, null, {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                            {{ form_widget(submissionForm.manuscriptUrl, {'attr': {'placeholder': 'https://...'}}) }}
                            {{ form_errors(submissionForm.manuscriptUrl) }}
                        </div>

                        <div class="rounded-[1.75rem] border border-dashed border-[rgba(6,27,176,0.2)] bg-[rgba(255,255,255,0.55)] px-5 py-6">
                            <p class="text-xs uppercase tracking-[0.24em] text-[#8B6B2E]">Pièce jointe / lien</p>
                            <p class="mt-3 text-sm leading-7 text-[rgba(6,27,176,0.78)]">
                                Pour le moment, la soumission se fait via un lien de lecture. Assurez-vous qu’il soit actif, accessible et lisible par notre comité.
                            </p>
                        </div>

                        <div aria-hidden="true">
                            {{ form_widget(submissionForm.company) }}
                        </div>

                        <div class="flex flex-col gap-3 pt-2 sm:flex-row">
                            <button type="submit" class="editorial-cta-primary">
                                Envoyer le manuscrit
                            </button>
                            <a href="{{ path('app_about') }}" class="editorial-cta-secondary">
                                Découvrir la maison
                            </a>
                        </div>
                    {{ form_end(submissionForm) }}
                </section>
            </div>
        </section>
    </div>
{% endblock %}
