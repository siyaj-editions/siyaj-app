{% extends 'base.html.twig' %}

{% block title %}Soumettre un manuscrit - SIYAJ Éditions{% endblock %}

{% block body %}
<section class="py-12 md:py-16">
    <div class="container">
        <div class="max-w-3xl mx-auto space-y-6">
            <div class="text-center space-y-3">
                <p class="text-sm text-sage uppercase tracking-[0.18em]">Auteurs</p>
                <h1 class="text-4xl md:text-5xl text-ink">Proposer un manuscrit</h1>
                <p class="text-ink/65 leading-relaxed">
                    Vous souhaitez être édité chez SIYAJ ? Envoyez votre projet au comité éditorial.
                    Décrivez votre manuscrit et ajoutez un lien de lecture si disponible.
                </p>
            </div>

            <section class="card p-6 md:p-8">
                {{ form_start(submissionForm, {'attr': {'class': 'space-y-6'}}) }}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            {{ form_label(submissionForm.firstname, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(submissionForm.firstname, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(submissionForm.firstname) }}
                        </div>
                        <div>
                            {{ form_label(submissionForm.lastname, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(submissionForm.lastname, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(submissionForm.lastname) }}
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            {{ form_label(submissionForm.email, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(submissionForm.email, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(submissionForm.email) }}
                        </div>
                        <div>
                            {{ form_label(submissionForm.phone, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(submissionForm.phone, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(submissionForm.phone) }}
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            {{ form_label(submissionForm.bookTitle, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(submissionForm.bookTitle, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(submissionForm.bookTitle) }}
                        </div>
                        <div>
                            {{ form_label(submissionForm.genre, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                            {{ form_widget(submissionForm.genre, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                            {{ form_errors(submissionForm.genre) }}
                        </div>
                    </div>

                    <div>
                        {{ form_label(submissionForm.synopsis, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                        {{ form_widget(submissionForm.synopsis, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper'}}) }}
                        {{ form_errors(submissionForm.synopsis) }}
                    </div>

                    <div>
                        {{ form_label(submissionForm.manuscriptUrl, null, {'label_attr': {'class': 'block text-xs font-semibold uppercase tracking-wider text-ink/50 mb-2'}}) }}
                        {{ form_widget(submissionForm.manuscriptUrl, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-black/10 bg-paper', 'placeholder': 'https://...'}}) }}
                        {{ form_errors(submissionForm.manuscriptUrl) }}
                    </div>

                    <div class="pt-2 flex flex-col sm:flex-row gap-3">
                        <button type="submit" class="btn btn-primary px-6 py-3">Envoyer ma proposition</button>
                        <a href="{{ path('app_about') }}" class="btn btn-secondary px-6 py-3">À propos de la maison</a>
                    </div>
                {{ form_end(submissionForm) }}
            </section>
        </div>
    </div>
</section>
{% endblock %}
