{% extends 'base.html.twig' %}

{% block title %}Inscription - SIYAJ Éditions{% endblock %}

{% block body %}
    <div class="bg-[#F7F4ED] text-[#061BB0]">
        <section class="container py-12 lg:py-16">
            <div class="mx-auto grid max-w-6xl overflow-hidden rounded-[2.5rem] border border-[rgba(6,27,176,0.08)] bg-white shadow-[0_24px_54px_rgba(6,27,176,0.08)] lg:grid-cols-[1.02fr_0.98fr]">
                <div class="p-8 lg:p-10">
                    <div class="mb-6">
                        <p class="section-kicker">Inscription</p>
                        <h1 class="editorial-title-md mt-3 text-[3.4rem]">Créer un compte</h1>
                        <p class="editorial-copy-soft mt-4">Rejoignez notre communauté de lectrices et lecteurs.</p>
                    </div>

                    {{ form_start(registrationForm, {'attr': {'class': 'space-y-5'}}) }}
                        <div class="grid gap-5 sm:grid-cols-2">
                            <div>
                                {{ form_label(registrationForm.firstname, 'Prénom', {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(registrationForm.firstname, {'attr': {'placeholder': 'Votre prénom'}}) }}
                                {{ form_errors(registrationForm.firstname) }}
                            </div>
                            <div>
                                {{ form_label(registrationForm.lastname, 'Nom', {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(registrationForm.lastname, {'attr': {'placeholder': 'Votre nom'}}) }}
                                {{ form_errors(registrationForm.lastname) }}
                            </div>
                        </div>

                        <div>
                            {{ form_label(registrationForm.email, 'Adresse email', {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                            {{ form_widget(registrationForm.email, {'attr': {'placeholder': 'votre@email.com'}}) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>

                        <div>
                            {{ form_label(registrationForm.numero, 'Numéro (téléphone)', {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                            {{ form_widget(registrationForm.numero, {'attr': {'placeholder': '06 12 34 56 78'}}) }}
                            {{ form_errors(registrationForm.numero) }}
                        </div>

                        <div class="grid gap-5 sm:grid-cols-2">
                            <div>
                                {{ form_label(registrationForm.plainPassword.first, 'Mot de passe', {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(registrationForm.plainPassword.first, {'attr': {'placeholder': 'Minimum 8 caractères'}}) }}
                                {{ form_errors(registrationForm.plainPassword.first) }}
                            </div>
                            <div>
                                {{ form_label(registrationForm.plainPassword.second, 'Confirmation', {'label_attr': {'class': 'mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]'}}) }}
                                {{ form_widget(registrationForm.plainPassword.second, {'attr': {'placeholder': 'Confirmez le mot de passe'}}) }}
                                {{ form_errors(registrationForm.plainPassword.second) }}
                            </div>
                        </div>

                        <div class="flex items-start gap-3 rounded-[1.25rem] border border-[rgba(6,27,176,0.08)] bg-[rgba(247,244,237,0.75)] p-4">
                            {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'mt-1 h-5 w-5 rounded border-[rgba(6,27,176,0.22)] text-[var(--register-blue-soft)] cursor-pointer'}}) }}
                            <div>
                                {{ form_label(registrationForm.agreeTerms, "J'accepte les conditions générales d'utilisation", {'label_attr': {'class': 'text-sm leading-6 text-[rgba(6,27,176,0.75)] cursor-pointer'}}) }}
                                {{ form_errors(registrationForm.agreeTerms) }}
                            </div>
                        </div>

                        <button type="submit" class="editorial-cta-primary w-full">
                            Créer mon compte
                        </button>
                    {{ form_end(registrationForm) }}

                    <div class="mt-8 border-t border-[rgba(6,27,176,0.08)] pt-6 text-center">
                        <p class="text-sm text-[rgba(6,27,176,0.55)]">Vous avez déjà un compte ?</p>
                        <a href="{{ path('app_login') }}" class="mt-2 inline-flex text-sm font-semibold uppercase tracking-[0.14em] text-[#EB5A27] transition hover:text-[#061BB0]">
                            Se connecter
                        </a>
                    </div>
                </div>

                <div class="relative hidden overflow-hidden lg:block p-10 text-white">
                    <img
                        src="{{ asset('images/auth/register-panel.jpg') }}"
                        alt="Univers de transmission Siyaj"
                        class="absolute inset-0 h-full w-full object-cover"
                        loading="lazy"
                        decoding="async"
                    >
                    <div class="absolute inset-0 bg-[rgba(6,27,176,0.5)]"></div>
                    <div class="relative z-10 flex h-full flex-col justify-between">
                        <div>
                            <p class="text-xs uppercase tracking-[0.24em] text-white/60">SIYAJ Éditions</p>
                            <h2 class="mt-5 text-4xl">Rejoindre une maison de lecture et de transmission.</h2>
                        </div>

                        <div class="space-y-4">
                            <div class="rounded-[1.6rem] border border-white/10 p-5" style="background:rgba(6,27,176,0.28);backdrop-filter:blur(10px);">
                                <p class="text-sm leading-7 text-white/82">Commandes, suivi, panier et expérience de lecture plus fluide dès la création du compte.</p>
                            </div>
                            <div class="rounded-[1.6rem] border border-white/10 p-5" style="background:rgba(6,27,176,0.28);backdrop-filter:blur(10px);">
                                <p class="text-sm leading-7 text-white/82">Une interface claire, plus éditoriale et plus cohérente avec la nouvelle direction du site.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
