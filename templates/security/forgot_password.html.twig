{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - SIYAJ Éditions{% endblock %}

{% block meta_description %}Réinitialise ton mot de passe SIYAJ en demandant un code envoyé par email.{% endblock %}

{% block robots %}noindex,nofollow{% endblock %}

{% block body %}
    <div class="bg-[#F7F4ED] text-[#061BB0]">
        <section class="container py-12 lg:py-16">
            <div class="mx-auto grid max-w-6xl overflow-hidden rounded-[2.5rem] border border-[rgba(6,27,176,0.08)] bg-white shadow-[0_24px_54px_rgba(6,27,176,0.08)] lg:grid-cols-[0.95fr_1.05fr]">
                <div class="p-8 lg:p-10">
                    <div class="mb-8">
                        <p class="section-kicker">Mot de passe oublié</p>
                        <h1 class="editorial-title-md mt-3 text-[3.4rem]">Recevoir un code de réinitialisation</h1>
                        <p class="editorial-copy-soft mt-4">Entre ton email pour recevoir un code à 6 chiffres et réinitialiser ton mot de passe.</p>
                    </div>

                    {{ form_start(requestForm, {'attr': {'class': 'space-y-5 auth-form', 'data-controller': 'form-feedback', 'novalidate': 'novalidate'}}) }}
                        <div>
                            <label for="{{ requestForm.email.vars.id }}" class="auth-form-label">Adresse email<span class="auth-form-asterisk">*</span></label>
                            {{ form_widget(requestForm.email, {'attr': {'placeholder': 'Ton@email.com', 'class': 'auth-form-input'}}) }}
                            {{ form_errors(requestForm.email) }}
                        </div>

                        <button type="submit" class="editorial-cta-primary w-full">
                            Envoyer le code
                        </button>
                    {{ form_end(requestForm) }}

                    <div class="mt-8 border-t border-[rgba(6,27,176,0.08)] pt-6 text-center">
                        <a href="{{ path('app_login') }}" class="inline-flex text-sm font-semibold uppercase tracking-[0.14em] text-[#EB5A27] transition hover:text-[#061BB0]">
                            Retour à la connexion
                        </a>
                    </div>
                </div>

                <div class="relative hidden overflow-hidden lg:block p-10 text-white">
                    <img
                        src="{{ asset('images/auth/login-panel.jpg') }}"
                        alt="Univers de lecture Siyaj"
                        class="absolute inset-0 h-full w-full object-cover"
                        loading="lazy"
                        decoding="async"
                    >
                    <div class="absolute inset-0 bg-[rgba(6,27,176,0.5)]"></div>
                    <div class="relative z-10 flex h-full flex-col justify-between">
                        <div>
                            <p class="text-xs uppercase tracking-[0.24em] text-white/60">SIYAJ Éditions</p>
                            <h2 class="mt-5 text-4xl">Un accès simple pour retrouver ton compte.</h2>
                        </div>

                        <div class="space-y-4">
                            <div class="rounded-[1.6rem] border border-white/10 p-5" style="background:rgba(6,27,176,0.28);backdrop-filter:blur(10px);">
                                <p class="text-sm leading-7 text-white/82">Si un compte existe avec ton adresse, un code à 6 chiffres te sera envoyé pour sécuriser la réinitialisation.</p>
                            </div>
                            <div class="rounded-[1.6rem] border border-white/10 p-5" style="background:rgba(6,27,176,0.28);backdrop-filter:blur(10px);">
                                <p class="text-sm leading-7 text-white/82">Le code est temporaire et permet uniquement de définir un nouveau mot de passe.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
