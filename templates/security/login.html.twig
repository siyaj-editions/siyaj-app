{% extends 'base.html.twig' %}

{% block title %}Connexion - SIYAJ Éditions{% endblock %}

{% block body %}
    <div class="bg-[#F7F4ED] text-[#061BB0]">
        <section class="container py-12 lg:py-16">
            <div class="mx-auto grid max-w-6xl overflow-hidden rounded-[2.5rem] border border-[rgba(6,27,176,0.08)] bg-white shadow-[0_24px_54px_rgba(6,27,176,0.08)] lg:grid-cols-[0.95fr_1.05fr]">
                <div class="p-8 lg:p-10">
                    <div class="mb-8">
                        <p class="section-kicker">Connexion</p>
                        <h1 class="editorial-title-md mt-3 text-[3.4rem]">Votre espace lecture</h1>
                        <p class="editorial-copy-soft mt-4">Accédez à votre espace personnel et à votre suivi de commandes.</p>
                    </div>

                    {% if error %}
                        <div class="mb-6 flex items-start gap-3 rounded-[1.25rem] border border-[rgba(235,90,39,0.24)] bg-[rgba(235,90,39,0.08)] p-4 text-sm text-[#EB5A27]">
                            <svg class="mt-0.5 h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                        </div>
                    {% endif %}

                    <form method="post" class="space-y-5">
                        <div>
                            <label for="inputEmail" class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]">
                                Adresse email
                            </label>
                            <input
                                type="email"
                                value="{{ last_username }}"
                                name="_username"
                                id="inputEmail"
                                class="w-full"
                                autocomplete="email"
                                required
                                autofocus
                                placeholder="votre@email.com"
                            >
                        </div>

                        <div>
                            <label for="inputPassword" class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[rgba(6,27,176,0.55)]">
                                Mot de passe
                            </label>
                            <input
                                type="password"
                                name="_password"
                                id="inputPassword"
                                class="w-full"
                                autocomplete="current-password"
                                required
                                placeholder="Votre mot de passe"
                            >
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button type="submit" class="editorial-cta-primary w-full">
                            Se connecter
                        </button>
                    </form>

                    <div class="mt-8 border-t border-[rgba(6,27,176,0.08)] pt-6 text-center">
                        <p class="text-sm text-[rgba(6,27,176,0.55)]">Vous n'avez pas de compte ?</p>
                        <a href="{{ path('app_register') }}" class="mt-2 inline-flex text-sm font-semibold uppercase tracking-[0.14em] text-[#EB5A27] transition hover:text-[#061BB0]">
                            Créer un compte
                        </a>
                    </div>
                </div>

                <div class="relative hidden overflow-hidden lg:block p-10 text-white">
                    <img
                        src="{{ asset('images/auth/login-panel.jpg') }}"
                        alt="Univers de lecture Siyaj"
                        class="absolute inset-0 h-full w-full object-cover"
                        loading="lazy"
                        decoding="async"
                    >
                    <div class="absolute inset-0 bg-[rgba(6,27,176,0.5)]"></div>
                    <div class="relative z-10 flex h-full flex-col justify-between">
                        <div>
                            <p class="text-xs uppercase tracking-[0.24em] text-white/60">SIYAJ Éditions</p>
                            <h2 class="mt-5 text-4xl">Un accès simple à votre univers de lecture.</h2>
                        </div>

                        <div class="space-y-4">
                            <div class="rounded-[1.6rem] border border-white/10 p-5" style="background:rgba(6,27,176,0.28);backdrop-filter:blur(10px);">
                                <p class="text-sm leading-7 text-white/82">Suivez vos commandes, retrouvez vos achats et gardez un accès fluide à votre espace lecteur.</p>
                            </div>
                            <div class="rounded-[1.6rem] border border-white/10 p-5" style="background:rgba(6,27,176,0.28);backdrop-filter:blur(10px);">
                                <p class="text-sm leading-7 text-white/82">Une expérience claire, soignée et cohérente avec le reste du site.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
