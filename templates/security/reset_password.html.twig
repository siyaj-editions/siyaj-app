{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mon mot de passe - SIYAJ Éditions{% endblock %}

{% block meta_description %}Vérifie ton code de réinitialisation et choisis un nouveau mot de passe pour ton compte SIYAJ.{% endblock %}

{% block robots %}noindex,nofollow{% endblock %}

{% block body %}
    <div class="bg-[#F7F4ED] text-[#061BB0]">
        <section class="container py-12 lg:py-16">
            <div class="mx-auto grid max-w-6xl overflow-hidden rounded-[2.5rem] border border-[rgba(6,27,176,0.08)] bg-white shadow-[0_24px_54px_rgba(6,27,176,0.08)] lg:grid-cols-[0.95fr_1.05fr]">
                <div class="p-8 lg:p-10">
                    <div class="mb-8">
                        <p class="section-kicker">Réinitialisation</p>
                        <h1 class="editorial-title-md mt-3 text-[3.2rem]">Entre le code reçu puis choisis un nouveau mot de passe</h1>
                        <p class="editorial-copy-soft mt-4">Le code est valide pendant 15 minutes. En cas d’erreur, tu pourras demander un nouveau code.</p>
                    </div>

                    {{ form_start(resetForm, {'attr': {'class': 'space-y-5 auth-form', 'data-controller': 'form-feedback', 'novalidate': 'novalidate'}}) }}
                        <div>
                            <label for="{{ resetForm.email.vars.id }}" class="auth-form-label">Adresse email<span class="auth-form-asterisk">*</span></label>
                            {{ form_widget(resetForm.email, {'attr': {'placeholder': 'Ton@email.com', 'class': 'auth-form-input'}}) }}
                            {{ form_errors(resetForm.email) }}
                        </div>

                        <div>
                            <label for="{{ resetForm.code.vars.id }}" class="auth-form-label">Code à 6 chiffres<span class="auth-form-asterisk">*</span></label>
                            {{ form_widget(resetForm.code, {'attr': {'placeholder': '123456', 'class': 'auth-form-input'}}) }}
                            {{ form_errors(resetForm.code) }}
                        </div>

                        <div class="grid gap-5 sm:grid-cols-2">
                            <div data-controller="password-toggle">
                                <label for="{{ resetForm.newPassword.first.vars.id }}" class="auth-form-label">Nouveau mot de passe<span class="auth-form-asterisk">*</span></label>
                                <div class="relative">
                                    {{ form_widget(resetForm.newPassword.first, {'attr': {'placeholder': 'Minimum 6 caractères', 'class': 'auth-form-input w-full pr-16', 'data-password-toggle-target': 'input'}}) }}
                                    <button
                                        type="button"
                                        class="absolute right-3 top-1/2 inline-flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full text-[rgba(6,27,176,0.6)] transition hover:text-[#F59A16]"
                                        data-action="click->password-toggle#toggle"
                                        data-password-toggle-target="label"
                                        aria-label="Afficher le mot de passe"
                                    >
                                        <svg data-password-toggle-target="showIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                                            <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7Z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                        <svg data-password-toggle-target="hideIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="hidden h-5 w-5" aria-hidden="true">
                                            <path d="m3 3 18 18"/>
                                            <path d="M10.584 10.587A2 2 0 0 0 10 12a2 2 0 0 0 2 2c.52 0 .993-.198 1.349-.523"/>
                                            <path d="M9.363 5.365A9.466 9.466 0 0 1 12 5c4.478 0 8.268 2.943 9.542 7a11.05 11.05 0 0 1-4.03 5.145"/>
                                            <path d="M6.228 6.228A11.013 11.013 0 0 0 2.458 12c1.274 4.057 5.064 7 9.542 7 1.27 0 2.48-.237 3.592-.67"/>
                                        </svg>
                                    </button>
                                </div>
                                {{ form_errors(resetForm.newPassword.first) }}
                            </div>
                            <div data-controller="password-toggle">
                                <label for="{{ resetForm.newPassword.second.vars.id }}" class="auth-form-label">Confirmation<span class="auth-form-asterisk">*</span></label>
                                <div class="relative">
                                    {{ form_widget(resetForm.newPassword.second, {'attr': {'placeholder': 'Confirme ton mot de passe', 'class': 'auth-form-input w-full pr-16', 'data-password-toggle-target': 'input'}}) }}
                                    <button
                                        type="button"
                                        class="absolute right-3 top-1/2 inline-flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full text-[rgba(6,27,176,0.6)] transition hover:text-[#F59A16]"
                                        data-action="click->password-toggle#toggle"
                                        data-password-toggle-target="label"
                                        aria-label="Afficher le mot de passe"
                                    >
                                        <svg data-password-toggle-target="showIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                                            <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7Z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                        <svg data-password-toggle-target="hideIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="hidden h-5 w-5" aria-hidden="true">
                                            <path d="m3 3 18 18"/>
                                            <path d="M10.584 10.587A2 2 0 0 0 10 12a2 2 0 0 0 2 2c.52 0 .993-.198 1.349-.523"/>
                                            <path d="M9.363 5.365A9.466 9.466 0 0 1 12 5c4.478 0 8.268 2.943 9.542 7a11.05 11.05 0 0 1-4.03 5.145"/>
                                            <path d="M6.228 6.228A11.013 11.013 0 0 0 2.458 12c1.274 4.057 5.064 7 9.542 7 1.27 0 2.48-.237 3.592-.67"/>
                                        </svg>
                                    </button>
                                </div>
                                {{ form_errors(resetForm.newPassword.second) }}
                            </div>
                        </div>

                        <button type="submit" class="editorial-cta-primary w-full">
                            Mettre à jour le mot de passe
                        </button>
                    {{ form_end(resetForm) }}

                    <div class="mt-8 border-t border-[rgba(6,27,176,0.08)] pt-6 text-center">
                        <a href="{{ path('app_forgot_password') }}" class="inline-flex text-sm font-semibold uppercase tracking-[0.14em] text-[#EB5A27] transition hover:text-[#061BB0]">
                            Demander un nouveau code
                        </a>
                    </div>
                </div>

                <div class="relative hidden overflow-hidden lg:block p-10 text-white">
                    <img
                        src="{{ asset('images/auth/register-panel.jpg') }}"
                        alt="Univers de transmission Siyaj"
                        class="absolute inset-0 h-full w-full object-cover"
                        loading="lazy"
                        decoding="async"
                    >
                    <div class="absolute inset-0 bg-[rgba(6,27,176,0.5)]"></div>
                    <div class="relative z-10 flex h-full flex-col justify-between">
                        <div>
                            <p class="text-xs uppercase tracking-[0.24em] text-white/60">SIYAJ Éditions</p>
                            <h2 class="mt-5 text-4xl">Un code, puis un nouveau mot de passe.</h2>
                        </div>

                        <div class="space-y-4">
                            <div class="rounded-[1.6rem] border border-white/10 p-5" style="background:rgba(6,27,176,0.28);backdrop-filter:blur(10px);">
                                <p class="text-sm leading-7 text-white/82">Le code reçu par email est temporaire et n’autorise que la réinitialisation du mot de passe.</p>
                            </div>
                            <div class="rounded-[1.6rem] border border-white/10 p-5" style="background:rgba(6,27,176,0.28);backdrop-filter:blur(10px);">
                                <p class="text-sm leading-7 text-white/82">En cas de doute ou d’expiration, tu peux demander un nouveau code en quelques secondes.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
